    display: inline-block;
    width: 1.5px;
    height: 13px;
    background: rgba(255,255,255,0.75);
    margin-left: 1px;
    vertical-align: middle;
    animation: hd-blink 0.7s step-end infinite;
  }
</style>

<script>import '../scripts/accordion';</script>

<script>
  // Hero demo: type URL → press button → fade to results → loop
  (async () => {
    const typedEl  = document.getElementById('hd-typed');
    const btn      = document.getElementById('hd-btn') as HTMLButtonElement;
    const formEl   = document.getElementById('hd-form');
    const resultEl = document.getElementById('hd-result');
    const bars     = Array.from(document.querySelectorAll<HTMLElement>('.hd-bar'));
    if (!typedEl || !btn || !formEl || !resultEl) return;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
    const url = 'mybusiness.com';

    while (true) {
      // Reset
      typedEl.textContent = '';
      formEl.style.opacity = '1';
      resultEl.style.opacity = '0';
      resultEl.style.pointerEvents = 'none';
      bars.forEach(b => { b.style.transitionDelay = '0s'; b.style.width = '0%'; });
      btn.style.transform = '';
      btn.style.boxShadow = '0 4px 14px rgba(46,117,182,0.35)';

      await sleep(900);

      // Type URL character by character
      for (const ch of url) {
        typedEl.textContent += ch;
        await sleep(60 + Math.random() * 60);
      }

      await sleep(500);

      // Button press: compress then release
      btn.style.transform = 'scale(0.92)';
      btn.style.boxShadow = '0 2px 8px rgba(46,117,182,0.15)';
      await sleep(130);
      btn.style.transform = 'scale(1.05)';
      btn.style.boxShadow = '0 8px 24px rgba(46,117,182,0.6)';
      await sleep(110);
      btn.style.transform = 'scale(1)';
      btn.style.boxShadow = '0 4px 14px rgba(46,117,182,0.35)';

      await sleep(300);

      // Fade form out, results in
      formEl.style.opacity = '0';
      await sleep(450);

      resultEl.style.opacity = '1';
      resultEl.style.pointerEvents = 'auto';
      bars.forEach((b, i) => {
        b.style.transitionDelay = `${i * 0.12}s`;
        b.style.width = (b.dataset.w ?? '0') + '%';
      });

      await sleep(3800);

      // Fade results out, reset
      resultEl.style.opacity = '0';
      resultEl.style.pointerEvents = 'none';
      await sleep(450);
    }
  })();
</script>
