---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuditForm from '../components/AuditForm.astro';

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'FAQPage',
  about:      { '@id': 'https://sequelwebstudio.com/#organization' },
  mainEntity: [
    { '@type': 'Question', name: 'What is the Pro Diagnosis + Remedy Package?', acceptedAnswer: { '@type': 'Answer', text: 'A 28-point deep technical scan of your existing website across 8 categories — performance, SEO, AI readiness, mobile, security, schema markup, analytics, and accessibility. Every issue is explained in plain English and paired with a ready-to-paste code fix. Delivered within 24 hours for a flat $350.' } },
    { '@type': 'Question', name: 'How is this different from a regular website audit?', acceptedAnswer: { '@type': 'Answer', text: "Most audits hand you a list of problems and walk away. The Pro Diagnosis + Remedy Package hands you the solutions too — ready-to-paste code blocks, platform-specific install steps (WordPress, Webflow, Squarespace, and more), and a priority-ranked action list so you know exactly what to fix first." } },
    { '@type': 'Question', name: 'Can I implement the fixes myself?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. That is by design. Every fix comes with plain-English instructions and ready-to-paste code. You do not need a developer. If you would rather have us implement the fixes, we offer that as a separate service.' } },
    { '@type': 'Question', name: 'What if my scores look fine on the free scan?', acceptedAnswer: { '@type': 'Answer', text: 'The free scan checks surface-level signals visible in your HTML. The Pro Diagnosis runs a live browser session, checking 28 technical layers that the quick scan cannot reach — including schema markup quality, AI crawler access, structured data completeness, and page speed internals.' } },
  ],
});
---

<BaseLayout
  title="Sequel Web Studio — AI Search Visibility for Small Businesses"
  description="Is your website invisible to ChatGPT and Google? 28-point Pro Diagnosis + Remedy Package — ready-to-paste fixes delivered in 24 hours for $350."
  ogImage="https://sequelwebstudio.com/images/og-home.png"
>
  <script type="application/ld+json" set:html={faqSchema} slot="head" />

  <!-- ── SECTION 1: HERO ── -->
  <section style="position: relative; background: #0F1F3D; min-height: 100vh; display: flex; align-items: center; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <!-- Animated glow blobs -->
    <div class="blob-1" style="position: absolute; top: 5%; left: -8%; width: 560px; height: 560px; border-radius: 50%; background: radial-gradient(circle, rgba(46,117,182,0.25) 0%, transparent 70%); pointer-events: none;"></div>
    <div class="blob-2" style="position: absolute; bottom: 10%; right: -4%; width: 440px; height: 440px; border-radius: 50%; background: radial-gradient(circle, rgba(142,68,173,0.2) 0%, transparent 70%); pointer-events: none;"></div>
    <div class="blob-3" style="position: absolute; top: 50%; left: 50%; width: 320px; height: 320px; border-radius: 50%; background: radial-gradient(circle, rgba(142,68,173,0.12) 0%, transparent 70%); transform: translate(-50%,-50%); pointer-events: none;"></div>

    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 120px 32px 80px; width: 100%;">
      <div style="display: flex; align-items: center; gap: 64px; flex-wrap: wrap;">

        <!-- Left: copy -->
        <div style="flex: 1 1 460px; min-width: 0;">
          <!-- Eyebrow pill -->
          <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.13); border-radius: 9999px; padding: 6px 14px; margin-bottom: 28px;">
            <div style="width: 7px; height: 7px; border-radius: 50%; background: #2E75B6; flex-shrink: 0; animation: pulse-dot 2s ease-in-out infinite;"></div>
            <span style="font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.65);">AI Search Visibility for Small Businesses</span>
          </div>

          <h1 style="font-size: clamp(30px, 4.2vw, 58px); font-weight: 700; color: white; line-height: 1.1; letter-spacing: -1.5px; margin-bottom: 24px;">
            To be found by AI search,<br />
            <span style="background: linear-gradient(135deg, #2E75B6, #8E44AD); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">your website needs a sequel.</span>
          </h1>

          <p style="font-size: 17px; color: rgba(255,255,255,0.7); line-height: 1.72; max-width: 520px; margin-bottom: 36px;">
            ChatGPT, Claude, Gemini, and Perplexity are answering your customers' questions right now, but they can't find your website. We'll show you exactly what's missing and hand you the remedy on a silver platter.
          </p>

          <a href="/audit#order" style="display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 15px 30px; border-radius: 10px; font-size: 16px; font-weight: 700; text-decoration: none; box-shadow: 0 8px 28px rgba(46,117,182,0.4); letter-spacing: -0.2px;">
            Get Your Pro Diagnosis — $350 →
          </a>

          <p style="margin-top: 14px; font-size: 13px; color: rgba(255,255,255,0.4);">
            Not sure yet?&nbsp;<a href="#free-audit" style="color: #4B9FD4; text-decoration: underline;">Get your free score first ↓</a>
          </p>

          <!-- Stats strip -->
          <div style="margin-top: 48px; display: flex; gap: 36px; flex-wrap: wrap;">
            {[['28-point', 'deep diagnosis'], ['24hr', 'delivery'], ['Ready-to-paste', 'code fixes']].map(([val, label]) => (
              <div>
                <div style="font-size: 22px; font-weight: 700; color: white; letter-spacing: -0.5px; line-height: 1;">{val}</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px;">{label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Pro Diagnosis preview card -->
        <div class="hero-card-col">
          <div id="hd-card" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.11); border-radius: 20px; padding: 28px; backdrop-filter: blur(12px); position: relative; overflow: hidden; min-height: 360px;">

            <!-- Form panel -->
            <div id="hd-form" style="transition: opacity 0.45s;">
              <div style="font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 14px;">Pro Diagnosis</div>
              <div style="font-size: 21px; font-weight: 700; color: white; line-height: 1.25; letter-spacing: -0.5px; margin-bottom: 14px;">
                See what your website is <span style="background: linear-gradient(90deg, #2E75B6, #8E44AD); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">missing.</span>
              </div>
              <p style="font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.65; margin-bottom: 18px;">
                28-point deep technical scan. Every issue explained in plain English. Ready-to-paste code for every fix.
              </p>
              <div style="display: flex; gap: 8px; flex-wrap: nowrap; margin-bottom: 10px;">
                <div style="flex: 1; padding: 10px 14px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); font-size: 13px; font-family: 'Space Mono', monospace; color: white; min-height: 40px; display: flex; align-items: center; overflow: hidden; min-width: 0;">
                  <span id="hd-typed"></span><span id="hd-cursor"></span>
                </div>
                <button id="hd-btn" type="button" style="flex-shrink: 0; padding: 10px 16px; border-radius: 8px; border: none; cursor: default; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; font-size: 13px; font-weight: 700; font-family: inherit; white-space: nowrap; box-shadow: 0 4px 14px rgba(46,117,182,0.35); transition: transform 0.12s, box-shadow 0.12s; pointer-events: none;">
                  Diagnose
                </button>
              </div>
              <p style="font-size: 11px; color: rgba(255,255,255,0.25); line-height: 1.5;">28-point scan · Plain-English report · 24hr delivery</p>
            </div>

            <!-- Results panel -->
            <div id="hd-result" style="position: absolute; inset: 0; padding: 28px; opacity: 0; pointer-events: none; transition: opacity 0.45s;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                <span style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4);">Pro Diagnosis Report</span>
                <span style="font-size: 10px; font-weight: 600; color: #4B9FD4; background: rgba(46,117,182,0.15); padding: 2px 9px; border-radius: 9999px;">Sample</span>
              </div>
              <div style="font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 14px; font-family: 'Space Mono', monospace;">mysmallbusiness.com</div>

              {[['Performance', 61, '#D97706'], ['SEO / AI Readiness', 44, '#DC2626'], ['AI Discoverability', 22, '#DC2626'], ['Mobile Experience', 94, '#16A34A'], ['Security', 55, '#D97706']].map(([label, score, color]) => (
                <div style="margin-bottom: 9px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <span style="font-size: 11px; color: rgba(255,255,255,0.6);">{label}</span>
                    <span style={`font-size: 11px; font-weight: 700; color: ${color};`}>{score}</span>
                  </div>
                  <div style="height: 4px; background: rgba(255,255,255,0.08); border-radius: 9999px; overflow: hidden;">
                    <div class="hd-bar" data-w={String(score)} style={`height: 4px; width: 0%; background: ${color}; border-radius: 9999px; transition: width 0.8s ease;`}></div>
                  </div>
                </div>
              ))}

              <div style="background: rgba(46,117,182,0.1); border: 1px solid rgba(46,117,182,0.25); border-radius: 8px; padding: 11px 14px; margin-top: 12px;">
                <div style="font-size: 12px; font-weight: 600; color: #4B9FD4; margin-bottom: 3px;">Remedy Package Included</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.35); line-height: 1.5; font-family: 'Space Mono', monospace;">schema.json · robots.txt · og-tags.html</div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>

    <!-- Wave to marquee -->
    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── MARQUEE ── -->
  <section style="background: white; padding: 24px 0; border-bottom: 1px solid #eaeff8; overflow: hidden;">
    <div style="overflow: hidden;">
      <div class="marquee-track">
        {[...Array(2)].map(() => (
          <div style="display: flex;">
            {['28-Point Diagnosis', 'Ready-to-Paste Fixes', 'AI Search Visibility', '24hr Delivery', 'ChatGPT Readable', 'Schema.org Markup', '95+ Lighthouse', 'Plain-English Explanations', 'Mobile-First', 'Priority-Ranked Action List'].map(item => (
              <span style="display: inline-flex; align-items: center; gap: 20px; padding: 0 28px; font-size: 15px; font-weight: 600; color: #8892A0; letter-spacing: 0.5px; text-transform: uppercase; white-space: nowrap;">
                <span style="width: 5px; height: 5px; border-radius: 50%; background: #2E75B6; flex-shrink: 0;"></span>
                {item}
              </span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SECTION 2: THE PROBLEM ── -->
  <section style="padding: 96px 0; background: white;">
    <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 800px; margin-bottom: 52px;">
        <span style="font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6;">The Problem</span>
        <h2 style="font-size: clamp(30px, 4vw, 50px); font-weight: 700; color: #0F1F3D; letter-spacing: -1.2px; line-height: 1.12; margin-top: 12px; margin-bottom: 20px;">Your website was written for the prior chapter.</h2>
        <p style="font-size: 16px; color: #595959; line-height: 1.72;">
          Search has a new chapter. AI assistants, voice search, and Google AI Overviews have rewritten how your customers find businesses. Most websites, even ones that look modern, are invisible to these new tools. Not because they're ugly. Because they weren't built for this.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 52px;">
        {[
          {
            num: '01',
            title: 'ChatGPT and Claude are the new search bar.',
            body: "A growing share of searches now happen inside AI assistants — \"find me a reliable lawn service near me\" — and these tools only quote websites they can read cleanly. If your site lacks structured data or buries content in heavy JavaScript, it's invisible. Your competitors who built for AI get the recommendation.",
          },
          {
            num: '02',
            title: 'Siri and Alexa want one answer, not ten.',
            body: "When someone asks their phone \"who does tile work near me,\" the assistant doesn't read off ten blue links, it picks one. The one that gets picked has clean schema data, proper Google Business Profile integration, and FAQ content structured for voice. Most local sites have none of those.",
          },
          {
            num: '03',
            title: 'Google now answers the question itself instead of sending traffic to you.',
            body: "When someone searches \"best taco shop nearby,\" Google often answers at the top of the page, pulling text directly from websites whose content is structured to be read by its AI. Sites that aren't structured this way get skipped. Your future customer gets the answer without ever seeing your name.",
          },
        ].map((card, i) => (
          <div class={`reveal reveal-delay-${i + 1} hover-card`} style="background: #F4F6FB; border-radius: 18px; padding: 32px 28px; border: 1px solid #e4eaf5; border-top: 3px solid #2E75B6; box-shadow: 0 6px 24px rgba(46,117,182,0.12);">
            <div style="display: inline-block; font-size: 11px; font-family: 'Space Mono', monospace; color: #2E75B6; letter-spacing: 1px; margin-bottom: 16px; background: rgba(46,117,182,0.1); padding: 3px 8px; border-radius: 6px;">{card.num}</div>
            <h3 style="font-size: 19px; font-weight: 700; color: #0F1F3D; line-height: 1.3; letter-spacing: -0.3px; margin-bottom: 12px;">{card.title}</h3>
            <p style="font-size: 14px; color: #595959; line-height: 1.68;">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SECTION 3: PRO DIAGNOSIS + REMEDY PACKAGE ── -->
  <section style="padding: 96px 0; background: #0F1F3D; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0; opacity: 0.4;"></div>
    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 0 32px;">

      <div class="reveal" style="max-width: 760px; margin-bottom: 64px;">
        <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Pro Diagnosis + Remedy Package</span>
        <h2 style="font-size: clamp(28px, 4vw, 52px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 12px; margin-bottom: 20px;">
          We find what's wrong.<br />We hand you how to fix it.
        </h2>
        <p style="font-size: 17px; color: rgba(255,255,255,0.65); line-height: 1.72; max-width: 620px;">
          Most audits hand you a list of problems and walk away. Ours doesn't. Every issue comes with a ready-to-paste code fix, platform-specific install steps, and a plain-English explanation of why it matters. You can implement it yourself in an afternoon.
        </p>
      </div>

      <!-- Two columns: feature list + gallery -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start;" class="diag-two-col">

        <!-- Left: features -->
        <div>
          <ul style="list-style: none; padding: 0; margin: 0 0 36px; display: flex; flex-direction: column; gap: 18px;">
            {[
              ['28-point deep technical scan', 'Run by a real AI agent in a live browser, not a surface-level check.'],
              ['Every issue explained in plain English', 'Not just flagged. You know what it means and why it matters for AI search.'],
              ['Ready-to-paste code for every fixable problem', 'Schema blocks, robots.txt, Open Graph tags, llms.txt, pre-filled with your real site data.'],
              ['Platform-specific install steps', 'WordPress, Webflow, Squarespace, Wix, Shopify, and more.'],
              ['Priority-ranked action list', 'Critical, high-value, and nice-to-have, so you know exactly what to fix first.'],
              ['Delivered within 24 hours', 'Flat $350. One-time payment. No subscription.'],
            ].map(([title, desc]) => (
              <li style="display: flex; gap: 14px; align-items: flex-start;">
                <div style="width: 22px; height: 22px; border-radius: 50%; background: rgba(46,117,182,0.15); border: 1.5px solid rgba(46,117,182,0.4); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                    <path d="M2 5l2 2 4-4" stroke="#2E75B6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div>
                  <div style="font-size: 15px; font-weight: 600; color: white; margin-bottom: 2px;">{title}</div>
                  <div style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.55;">{desc}</div>
                </div>
              </li>
            ))}
          </ul>

        </div>

        <!-- Right: code block + price/CTA -->
        <div class="reveal reveal-delay-2">

          <!-- Code block preview -->
          <div class="code-preview">
            <div class="code-preview-header">
              <div style="display: flex; gap: 5px; align-items: center;">
                <span style="width: 9px; height: 9px; border-radius: 50%; background: #ff5f57;"></span>
                <span style="width: 9px; height: 9px; border-radius: 50%; background: #ffbd2e;"></span>
                <span style="width: 9px; height: 9px; border-radius: 50%; background: #28c840;"></span>
              </div>
              <span class="code-filename">structured-data.json — Ready to paste</span>
              <span class="code-badge-ready">Remedy Included</span>
            </div>
            <pre class="code-content"><code>{`{
  `}<span style="color: #79b8ff">"@context"</span>{`: `}<span style="color: #a8d5a2">"https://schema.org"</span>{`,
  `}<span style="color: #79b8ff">"@type"</span>{`: `}<span style="color: #a8d5a2">"LocalBusiness"</span>{`,
  `}<span style="color: #79b8ff">"name"</span>{`: `}<span style="color: #a8d5a2">"Your Business Name"</span>{`,
  `}<span style="color: #79b8ff">"telephone"</span>{`: `}<span style="color: #a8d5a2">"+1-817-555-5555"</span>{`,
  `}<span style="color: #79b8ff">"url"</span>{`: `}<span style="color: #a8d5a2">"https://yourbusiness.com"</span>{`
}`}</code></pre>
          </div>

          <div style="margin-top: 28px; display: flex; align-items: baseline; gap: 10px; margin-bottom: 16px;">
            <span style="font-size: 42px; font-weight: 700; color: white; letter-spacing: -2px;">$350</span>
            <span style="font-size: 14px; color: rgba(255,255,255,0.45);">flat · one-time · delivered in 24 hours</span>
          </div>
          <a href="/audit#order" style="display: inline-block; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 700; text-decoration: none; box-shadow: 0 8px 28px rgba(46,117,182,0.35);">
            Order Your Pro Diagnosis →
          </a>
          <p style="margin-top: 10px; font-size: 12px; color: rgba(255,255,255,0.35);">One-time payment · No subscription · Money-back guarantee if we can't find anything to improve</p>
        </div>

      </div>
    </div>

      <!-- Full-width sample image carousel -->
      <div style="max-width: 1160px; margin: 56px auto 0; padding: 0 32px;">
      <div class="reveal">
        <p style="font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.65); margin-bottom: 20px; letter-spacing: 0.3px;">Sample deliverable pages — names redacted</p>
        <div class="gallery-wrapper-dark">
          <button class="gallery-arrow-dark gallery-arrow-dark-left" aria-label="Scroll left" style="display:none;">&#8592;</button>
          <button class="gallery-arrow-dark gallery-arrow-dark-right" aria-label="Scroll right">&#8594;</button>
          <div class="deliverable-gallery-dark" id="homepage-gallery-scroll">
            {[
              ['/images/sample-deliverables/sample-1-title-page.webp',           'Title Page'],
              ['/images/sample-deliverables/sample-2-exec-summary.webp',          'Exec Summary'],
              ['/images/sample-deliverables/sample-4-priority-list.webp',         'Priority List'],
              ['/images/sample-deliverables/sample-5-remedy-steps.webp',          'Remedy Steps'],
              ['/images/sample-deliverables/sample-6-remedy-steps-with-code.webp','Remedy + Code'],
              ['/images/sample-deliverables/sample-3-whats-included.webp',        "What's Included"],
              ['/images/sample-deliverables/sample-7-full-audit-results.webp',    'Full Results'],
            ].map(([img, label]) => (
              <div class="sample-thumb-wrap-dark" data-lightbox-trigger data-img={img} data-label={label}>
                <div class="browser-frame">
                  <div class="browser-chrome">
                    <span class="browser-dot"></span><span class="browser-dot"></span><span class="browser-dot"></span>
                    <span class="browser-address">{label}</span>
                  </div>
                  <img src={img} alt={`${label} — Pro Diagnosis sample`} loading="lazy" width="752" height="757" class="sample-thumb-dark" />
                </div>
                <span class="sample-label-dark">{label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      </div>

    <!-- Lightbox overlay -->
    <div id="lightbox" style="display: none; position: fixed; inset: 0; background: rgba(5,12,28,0.93); z-index: 1000; align-items: center; justify-content: center; flex-direction: column; padding: 40px 20px; cursor: zoom-out;" role="dialog" aria-modal="true" aria-label="Image preview">
      <button id="lightbox-close" style="position: absolute; top: 20px; right: 24px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.7); width: 38px; height: 38px; border-radius: 50%; cursor: pointer; font-size: 17px; font-family: inherit; display: flex; align-items: center; justify-content: center; z-index: 1;" aria-label="Close preview">✕</button>
      <div id="lightbox-content" style="display: flex; flex-direction: column; align-items: center; cursor: default; max-width: 90vw;" onclick="event.stopPropagation()">
        <img id="lightbox-img" src="" alt="" style="max-width: 88vw; max-height: 72vh; border-radius: 10px; object-fit: contain; box-shadow: 0 32px 80px rgba(0,0,0,0.6); display: block;" />
        <div id="lightbox-caption" style="margin-top: 18px; text-align: center; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; max-width: 600px; width: 90vw;">
          <div style="font-size: 10px; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase; color: rgba(100,180,230,0.65); margin-bottom: 7px;">Sample Deliverable</div>
          <div id="lightbox-caption-title" style="font-size: 17px; font-weight: 600; color: rgba(255,255,255,0.92); letter-spacing: -0.2px;"></div>
        </div>
      </div>
    </div>

    <!-- Angular clip to next section -->
    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 60 L1440 0 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── SECTION 4: AFTER YOUR DIAGNOSIS ── -->
  <section style="padding: 96px 0; background: white;">
    <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 860px; margin-bottom: 52px;">
