---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuditForm from '../components/AuditForm.astro';
import { PORTFOLIO } from '../data/portfolio';

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: "What's included in the price?",  acceptedAnswer: { '@type': 'Answer', text: 'Design, build, launch, and the full technical foundation — schema markup, sitemap, analytics setup, contact form, and 30 days of post-launch support.' } },
    { '@type': 'Question', name: 'What about hosting?',            acceptedAnswer: { '@type': 'Answer', text: 'We handle hosting for $20/month. That covers your server, SSL certificate, and uptime monitoring — no setup required on your end.' } },
    { '@type': 'Question', name: 'How long does it take?',         acceptedAnswer: { '@type': 'Answer', text: 'Most sites launch in 2–3 weeks, depending on how quickly content is available.' } },
    { '@type': 'Question', name: 'Do you do ongoing updates?',     acceptedAnswer: { '@type': 'Answer', text: 'Future support is available at a rate of $60/hour with a half-hour minimum.' } },
  ],
});

const layers = [
  {
    num: '01', title: 'Discoverability', sub: 'Your business shows up wherever people are searching.',
    items: [
      "Schema.org structured data (LocalBusiness, FAQPage, Review) — tells Google and AI tools exactly what your business is and what it offers",
      "llms.txt — the emerging standard for telling AI assistants what they're allowed to quote from your site",
      "Robots.txt configured for AI crawlers — explicit opt-in for GPTBot, ClaudeBot, Google-Extended, PerplexityBot",
      "Google Business Profile integration with consistent Name/Address/Phone across the web",
      "Open Graph and Twitter card tags so your site looks clean when shared on social",
      "FAQ content structured for voice search — so Siri and Alexa can quote you",
    ],
  },
  {
    num: '02', title: 'Conversion', sub: 'Visitors become customers, not just pageviews.',
    items: [
      "One clear call-to-action on every page — no clutter, no dead ends",
      "Tappable phone numbers on mobile — one touch to call",
      "Embedded booking widget tuned to your business type (OpenTable, Calendly, Square Appointments)",
      "Short contact form that emails you directly",
      "Trust signals designed in — Google review count, years in business, certifications, badges",
      "Embedded Google Map with hours, address, and parking notes",
    ],
  },
  {
    num: '03', title: 'Foundation', sub: 'The technical basics, done right.',
    items: [
      "Sub-1-second page loads on mobile — Google PageSpeed Insights score 95+ out of the box",
      "Mobile-first responsive design — because most local searches happen on a phone",
      "Semantic HTML — machine-readable structure",
      "XML sitemap submitted to Google",
      "Image optimization — WebP format, lazy loading, responsive sizing",
      "Clean URL structure — readable to humans and search engines",
      "HTTPS/SSL encryption — automatic, always on",
    ],
  },
  {
    num: '04', title: 'Measurement', sub: 'You can see it working.',
    items: [
      "Google Analytics 4 with conversion events — we track actual actions (form submitted, phone called), not just pageviews",
      "Google Search Console set up and connected — see which searches bring you visitors",
      "Monthly one-page report delivered to your inbox, in plain English",
      "Uptime monitoring — if the site goes down, you get an email",
    ],
  },
  {
    num: '05', title: 'Legal & Compliance', sub: 'Built to the standard regulators now expect.',
    items: [
      "Privacy policy — required because Google Analytics collects visitor data",
      "Cookie consent banner — GDPR and CCPA ready",
      "HTTPS encryption — required by modern browsers, often missing on older sites",
    ],
  },
  {
    num: '06', title: 'Longevity', sub: 'A site that still works five years from now.',
    items: [
      "Branded 404 page so lost visitors don't bounce",
      "Editable sections — you can update hours, menu items, and photos yourself without calling us",
      "Clean handoff documentation — any developer can maintain your site if we ever part ways",
    ],
  },
];

---

<BaseLayout
  title="Sequel Web Studio"
  description="Sequel Web Studio builds custom-coded websites for small businesses across the US that get found on Google, ChatGPT, and voice search. Starting at $1,000."
>
  <script type="application/ld+json" set:html={faqSchema} slot="head" />

  <!-- ── SECTION 1: HERO ── -->
  <section style="position: relative; background: #0F1F3D; min-height: 100vh; display: flex; align-items: center; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <!-- Glow blobs -->
    <div style="position: absolute; top: 5%; left: -8%; width: 560px; height: 560px; border-radius: 50%; background: radial-gradient(circle, rgba(46,117,182,0.22) 0%, transparent 70%); pointer-events: none;"></div>
    <div style="position: absolute; bottom: 10%; right: -4%; width: 440px; height: 440px; border-radius: 50%; background: radial-gradient(circle, rgba(142,68,173,0.18) 0%, transparent 70%); pointer-events: none;"></div>

    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 120px 32px 80px; width: 100%;">
      <div style="display: flex; align-items: center; gap: 64px; flex-wrap: wrap;">

        <!-- Left: copy -->
        <div style="flex: 1 1 460px; min-width: 0;">
          <!-- Eyebrow pill -->
          <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.13); border-radius: 9999px; padding: 6px 14px; margin-bottom: 28px;">
            <div style="width: 7px; height: 7px; border-radius: 50%; background: #4B9FD4; flex-shrink: 0;"></div>
            <span style="font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.65);">Providing Small Businesses With Top Tier Visibility</span>
          </div>

          <h1 style="font-size: clamp(38px, 5.5vw, 72px); font-weight: 700; color: white; line-height: 1.08; letter-spacing: -2px; margin-bottom: 24px;">
            Websites that work<br />
            with how people<br />
            <span class="grad-text">search today.</span>
          </h1>

          <p style="font-size: 17px; color: rgba(255,255,255,0.62); line-height: 1.72; max-width: 500px; margin-bottom: 36px;">
            We build new websites and modernize existing websites so ChatGPT, Claude, Gemini, and Perplexity can find them. Either path — starting at $1,000, done for you.
          </p>

          <a href="#audit-form" style="display: inline-block; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 700; text-decoration: none; box-shadow: 0 8px 24px rgba(46,117,182,0.4); letter-spacing: -0.2px;">
            Get Your Free Website Audit →
          </a>

          <p style="margin-top: 14px; font-size: 13px; color: rgba(255,255,255,0.4);">
            Or learn about:&nbsp;
            <a href="/services" style="color: #4B9FD4; text-decoration: underline;">New Sites</a>
            &nbsp;·&nbsp;
            <a href="/services" style="color: #4B9FD4; text-decoration: underline;">Modernizing</a>
          </p>

          <!-- Stats strip -->
          <div style="margin-top: 48px; display: flex; gap: 36px; flex-wrap: wrap;">
            {[['30+', 'signals in our free audit'], ['6', 'layers of technical foundation'], ['$1,000', 'starting price']].map(([val, label]) => (
              <div>
                <div style="font-size: 26px; font-weight: 700; color: white; letter-spacing: -1px; line-height: 1;">{val}</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px;">{label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: animated audit demo card -->
        <div class="hero-card-col">
          <div id="hd-card" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.11); border-radius: 20px; padding: 28px; backdrop-filter: blur(12px); position: relative; overflow: hidden;">

            <!-- Form panel — determines card height -->
            <div id="hd-form" style="transition: opacity 0.45s;">
              <div style="font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 14px;">Ready?</div>
              <div style="font-size: 21px; font-weight: 700; color: white; line-height: 1.25; letter-spacing: -0.5px; margin-bottom: 14px;">
                See what your website is <span style="background: linear-gradient(90deg, #4B9FD4, #8E44AD); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">missing.</span>
              </div>
              <p style="font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.65; margin-bottom: 18px;">
                It takes less than a minute. No email required to see your score. If your site is in good shape, you'll know. If it isn't, you'll know exactly what to fix.
              </p>
              <div style="display: flex; gap: 8px; flex-wrap: nowrap; margin-bottom: 10px;">
                <div style="flex: 1; padding: 10px 14px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); font-size: 13px; font-family: 'Space Mono', monospace; color: white; min-height: 40px; display: flex; align-items: center; overflow: hidden; min-width: 0;">
                  <span id="hd-typed"></span><span id="hd-cursor"></span>
                </div>
                <button id="hd-btn" type="button" style="flex-shrink: 0; padding: 10px 16px; border-radius: 8px; border: none; cursor: default; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; font-size: 13px; font-weight: 700; font-family: inherit; white-space: nowrap; box-shadow: 0 4px 14px rgba(46,117,182,0.35); transition: transform 0.12s, box-shadow 0.12s; pointer-events: none;">
                  Run Free Audit
                </button>
              </div>
              <p style="font-size: 11px; color: rgba(255,255,255,0.25); line-height: 1.5;">No email required. No credit card. No sales call unless you ask.</p>
            </div>

            <!-- Results panel — absolute overlay, fades in over the form -->
            <div id="hd-result" style="position: absolute; inset: 0; padding: 28px; opacity: 0; pointer-events: none; transition: opacity 0.45s;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                <span style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4);">Free Audit Report</span>
                <span style="font-size: 10px; font-weight: 600; color: #4B9FD4; background: rgba(75,159,212,0.15); padding: 2px 9px; border-radius: 9999px;">Example</span>
              </div>
              <div style="font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 14px; font-family: 'Space Mono', monospace;">mysmallbusiness.com</div>

              {[['Performance', 61, '#D97706'], ['SEO / AI Readiness', 44, '#DC2626'], ['Mobile Experience', 94, '#16A34A'], ['Security', 55, '#D97706']].map(([label, score, color]) => (
                <div style="margin-bottom: 10px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span style="font-size: 12px; color: rgba(255,255,255,0.6);">{label}</span>
                    <span style={`font-size: 12px; font-weight: 700; color: ${color};`}>{score}</span>
                  </div>
                  <div style="height: 4px; background: rgba(255,255,255,0.08); border-radius: 9999px; overflow: hidden;">
                    <div class="hd-bar" data-w={String(score)} style={`height: 4px; width: 0%; background: ${color}; border-radius: 9999px; transition: width 0.8s ease;`}></div>
                  </div>
                </div>
              ))}

              <div style="background: rgba(220,38,38,0.1); border: 1px solid rgba(220,38,38,0.2); border-radius: 8px; padding: 11px 14px; margin-top: 12px;">
                <div style="font-size: 12px; font-weight: 600; color: #FCA5A5; margin-bottom: 3px;">3 Critical Issues Found</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.35); line-height: 1.5;">Missing Schema.org markup · No AI crawler access · No mobile viewport</div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>

    <!-- Wave to white marquee -->
    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── MARQUEE ── -->
  <section style="background: white; padding: 24px 0; border-bottom: 1px solid #eaeff8; overflow: hidden;">
    <div style="overflow: hidden;">
      <div class="marquee-track">
        {[...Array(2)].map(() => (
          <div style="display: flex;">
            {['Custom-Coded', 'AI-Readable', 'Nationwide', 'No Templates', 'Schema.org Markup', 'Voice-Search Ready', '95+ Lighthouse', 'Google Business Profile', 'Mobile-First'].map(item => (
              <span style="display: inline-flex; align-items: center; gap: 20px; padding: 0 28px; font-size: 15px; font-weight: 600; color: #8892A0; letter-spacing: 0.5px; text-transform: uppercase; white-space: nowrap;">
                <span style="width: 5px; height: 5px; border-radius: 50%; background: #8E44AD; flex-shrink: 0;"></span>
                {item}
              </span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SECTION 2: SEARCH IS CHANGING ── -->
  <section style="padding: 96px 0; background: white;">
    <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 800px; margin-bottom: 52px;">
        <span style="font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6;">The Problem</span>
        <h2 style="font-size: clamp(30px, 4vw, 50px); font-weight: 700; color: #0F1F3D; letter-spacing: -1.2px; line-height: 1.12; margin-top: 12px; margin-bottom: 20px;">Search isn't what it used to be.</h2>
        <p style="font-size: 16px; color: #595959; line-height: 1.72;">
          Two years ago, people found a local business by typing its name into Google and clicking the first blue link. That's not how it works anymore. Today, the same question gets asked three different ways — and a traditional website usually lands in none of them.
        </p>
      </div>

      <!-- 3-card grid -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 52px;">
        {[
          {
            num: '01',
            title: 'ChatGPT and Claude are the new search bar.',
            body: "A growing share of searches now happen inside AI assistants — \"find me a reliable lawn service near me\" — and these tools only quote websites they can read cleanly. If your site buries its content in heavy JavaScript or lacks structured data, it's invisible. Your competitors who built for AI get the recommendation.",
          },
          {
            num: '02',
            title: 'Siri and Alexa want one answer, not ten.',
            body: "When someone asks their phone \"who does tile work near me,\" the assistant doesn't read off ten blue links — it picks one. The one that gets picked has clean schema data, proper Google Business Profile integration, and FAQ content structured for voice. Most local sites have none of those.",
          },
          {
            num: '03',
            title: 'Google now answers the question itself instead of sending traffic to you.',
            body: "When someone searches \"best taco shop nearby,\" Google often answers at the top of the page — pulling text directly from websites whose content is structured to be read by its AI. Sites that aren't structured this way get skipped. Your future customer gets the answer without ever seeing your name.",
          },
        ].map((card, i) => (
          <div class={`reveal reveal-delay-${i + 1} hover-card`} style="background: #F4F6FB; border-radius: 18px; padding: 32px 28px; border: 1px solid #e4eaf5; box-shadow: 0 4px 16px rgba(15,31,61,0.06);">
            <div style="font-size: 12px; font-family: 'Space Mono', monospace; color: #2E75B6; letter-spacing: 1px; margin-bottom: 16px;">{card.num}</div>
            <h3 style="font-size: 19px; font-weight: 700; color: #0F1F3D; line-height: 1.3; letter-spacing: -0.3px; margin-bottom: 12px;">{card.title}</h3>
            <p style="font-size: 14px; color: #595959; line-height: 1.68;">{card.body}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── SECTION 2B: THE FIX ── -->
  <section style="padding: 96px 0 152px; background: linear-gradient(135deg, #0F1F3D 0%, #1F3864 60%, #2E75B6 100%); position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0; opacity: 0.3;"></div>
    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 800px; margin-bottom: 52px;">
        <span style="font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #16A34A;">The Fix</span>
        <h2 style="font-size: clamp(30px, 4vw, 50px); font-weight: 700; color: white; letter-spacing: -1.2px; line-height: 1.12; margin-top: 12px; margin-bottom: 20px;">Websites built for the way search works now.</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.62); line-height: 1.72;">
          The good news: this is a solvable problem. We build and modernize websites so they are found by the tools your customers use today, whether that is ChatGPT, a voice assistant, or Google.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
        {[
          {
            num: '01',
            title: 'We make your site readable by AI assistants.',
            body: "ChatGPT, Claude, and Gemini pull from sites with clean, structured content. We build yours with semantic HTML and schema.org data so AI tools can find, quote, and recommend you — instead of a competitor.",
          },
          {
            num: '02',
            title: 'We structure your content for voice and assistant search.',
            body: "Getting picked by Siri or Alexa isn't random. It requires clean schema data, a tight Google Business Profile, and FAQ content written the way people speak. We build all of that in from day one.",
          },
          {
            num: '03',
            title: "We help Google's AI include you — not bypass you.",
            body: "Google's AI Overviews pull from sites with structured, machine-readable content. We make sure yours qualifies — so when someone searches your category, your business is part of the answer.",
          },
        ].map((card, i) => (
          <div class={`reveal reveal-delay-${i + 1} hover-card`} style="background: rgba(255,255,255,0.07); border-radius: 18px; padding: 32px 28px; border: 1px solid rgba(255,255,255,0.12);">
            <div style="font-size: 12px; font-family: 'Space Mono', monospace; color: #16A34A; letter-spacing: 1px; margin-bottom: 16px;">{card.num}</div>
            <h3 style="font-size: 19px; font-weight: 700; color: white; line-height: 1.3; letter-spacing: -0.3px; margin-bottom: 12px;">{card.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.68;">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
    <!-- Wave to white Six-Layer Foundation -->
    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── SECTION 5: SIX-LAYER FOUNDATION ── -->
  <section style="padding: 96px 0; background: white;">
    <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 680px; margin-bottom: 52px;">
        <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6;">The Technical Foundation</span>
        <h2 style="font-size: clamp(28px, 4vw, 48px); font-weight: 700; color: #0F1F3D; letter-spacing: -1px; line-height: 1.12; margin-top: 12px; margin-bottom: 16px;">
          Most designers stop at the pretty. We don't.
        </h2>
        <p style="font-size: 16px; color: #595959; line-height: 1.72;">
          Every Sequel Web Studio site — whether new or modernized — is built on a six-layer technical foundation. This is what separates a site that looks good from a site that actually gets found, converts visitors into customers, and keeps working five years from now.
        </p>
      </div>

      <!-- Accordion -->
      <div class="reveal accordion" data-accordion>
        {layers.map((layer, i) => (
          <div class="acc-item" data-acc-item>
            <button class="acc-header" data-acc-btn type="button" aria-expanded="false" aria-controls={`acc-body-${i}`}>
              <span class="acc-num">{layer.num}</span>
              <span class="acc-meta">
                <span class="acc-title">{layer.title}</span>
                <span class="acc-sub">{layer.sub}</span>
              </span>
              <span class="acc-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <line x1="7" y1="0" x2="7" y2="14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <line x1="0" y1="7" x2="14" y2="7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
            <div class="acc-body" data-acc-body id={`acc-body-${i}`}>
              <ul class="acc-list">
                {layer.items.map(item => (
                  <li class="acc-list-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;">
                      <circle cx="8" cy="8" r="7" fill="rgba(75,159,212,0.2)" />
                      <path d="M5 8l2 2 4-4" stroke="#4B9FD4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <!-- Callout bar -->
      <div class="reveal" style="margin-top: 28px; background: #F4F6FB; border-radius: 14px; border: 2px solid #e4eaf5; padding: 24px 28px; display: flex; align-items: center; gap: 16px;">
        <div style="width: 3px; height: 48px; background: #8E44AD; border-radius: 9999px; flex-shrink: 0;"></div>
        <p style="font-size: 16px; font-weight: 500; color: #0F1F3D; line-height: 1.55; margin: 0;">
          When a graphic designer builds you a website, you get the first layer. When we build you a website, you get all six.
        </p>
      </div>

    </div>
  </section>

  <!-- ── SECTION 4: FREE AUDIT FORM ── -->
  <section id="audit-form" style="padding: 96px 0 152px; background: #0F1F3D; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1; max-width: 760px; margin: 0 auto; padding: 0 32px; text-align: center;">
      <div class="reveal">
        <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4; display: block; margin-bottom: 16px;">Where to Start</span>
        <h2 style="font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: white; letter-spacing: -1px; line-height: 1.12; margin-bottom: 20px;">
          See exactly what your website is missing — in 60 seconds, for free.
        </h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.55); line-height: 1.72; max-width: 560px; margin: 0 auto 36px;">
          Paste your URL. We check more than 30 signals that determine whether Google's AI, ChatGPT, and voice assistants can actually find your business. You get a scored report, a plain-English explanation of what each signal means, and a ranked list of what to fix — even if you never hire us to fix it.
        </p>
        <div style="text-align: left; max-width: 560px; margin: 0 auto;">
          <AuditForm dark />
        </div>
      </div>
    </div>
    <!-- Wave to white Two Paths -->
    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── SECTION 3: TWO PATHS ── -->
  <section style="padding: 96px 0; background: white;">
    <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 600px; margin-bottom: 52px;">
