  .portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s ease;
  }
  .portfolio-card:hover .portfolio-img {
    transform: scale(1.04) translateY(-2%);
  }

  /* Accordion */
  .accordion { display: flex; flex-direction: column; gap: 2px; }

  .acc-item {
    background: #0F1F3D;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
    transition: background 0.3s, border-color 0.3s;
  }
  .acc-item.is-open {
    background: white;
    border-color: #e4eaf5;
  }

  .acc-header {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 22px 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: inherit;
  }

  .acc-num {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: #4B9FD4;
    letter-spacing: 1px;
    min-width: 32px;
    flex-shrink: 0;
    transition: color 0.3s;
  }
  .acc-item.is-open .acc-num { color: #2E75B6; }

  .acc-meta { flex: 1; min-width: 0; }
  .acc-title {
    display: block;
    font-size: 17px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.2px;
    transition: color 0.3s;
  }
  .acc-item.is-open .acc-title { color: #0F1F3D; }
  .acc-sub {
    display: block;
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    margin-top: 2px;
    transition: color 0.3s;
  }
  .acc-item.is-open .acc-sub { color: #8892A0; }

  .acc-icon {
    flex-shrink: 0;
    color: rgba(255,255,255,0.4);
    transition: transform 0.2s, color 0.3s;
    line-height: 0;
  }
  .acc-item.is-open .acc-icon {
    transform: rotate(45deg);
    color: #8892A0;
  }

  .acc-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .acc-list {
    list-style: none;
    padding: 4px 28px 24px 76px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
  }
  .acc-list-item {
    display: flex;
    gap: 10px;
    font-size: 14px;
    color: #595959;
    line-height: 1.55;
    align-items: flex-start;
  }

  /* Hero demo card cursor */
  @keyframes hd-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  #hd-cursor {
    display: inline-block;
    width: 1.5px;
    height: 13px;
    background: rgba(255,255,255,0.75);
    margin-left: 1px;
    vertical-align: middle;
    animation: hd-blink 0.7s step-end infinite;
  }
</style>

<script>
  // Accordion: one open at a time
  const accordion = document.querySelector<HTMLElement>('[data-accordion]');
  if (accordion) {
    const items = accordion.querySelectorAll<HTMLElement>('[data-acc-item]');
    items.forEach(item => {
      const btn  = item.querySelector<HTMLButtonElement>('[data-acc-btn]')!;
      const body = item.querySelector<HTMLElement>('[data-acc-body]')!;

      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');

        // Close all
        items.forEach(i => {
          i.classList.remove('is-open');
          (i.querySelector('[data-acc-body]') as HTMLElement).style.maxHeight = '0';
          (i.querySelector('[data-acc-btn]') as HTMLElement).setAttribute('aria-expanded', 'false');
        });

        // Open if was closed
        if (!isOpen) {
          item.classList.add('is-open');
          body.style.maxHeight = body.scrollHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  // Hero demo: type URL → press button → fade to results → loop
  (async () => {
    const typedEl  = document.getElementById('hd-typed');
    const btn      = document.getElementById('hd-btn') as HTMLButtonElement;
    const formEl   = document.getElementById('hd-form');
    const resultEl = document.getElementById('hd-result');
    const bars     = Array.from(document.querySelectorAll<HTMLElement>('.hd-bar'));
    if (!typedEl || !btn || !formEl || !resultEl) return;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
    const url = 'mybusiness.com';

    while (true) {
      // Reset
      typedEl.textContent = '';
      formEl.style.opacity = '1';
      resultEl.style.opacity = '0';
      resultEl.style.pointerEvents = 'none';
      bars.forEach(b => { b.style.transitionDelay = '0s'; b.style.width = '0%'; });
      btn.style.transform = '';
      btn.style.boxShadow = '0 4px 14px rgba(46,117,182,0.35)';

      await sleep(900);

      // Type URL character by character
      for (const ch of url) {
        typedEl.textContent += ch;
        await sleep(60 + Math.random() * 60);
      }

      await sleep(500);

      // Button press: compress then release
      btn.style.transform = 'scale(0.92)';
      btn.style.boxShadow = '0 2px 8px rgba(46,117,182,0.15)';
      await sleep(130);
      btn.style.transform = 'scale(1.05)';
      btn.style.boxShadow = '0 8px 24px rgba(46,117,182,0.6)';
      await sleep(110);
      btn.style.transform = 'scale(1)';
      btn.style.boxShadow = '0 4px 14px rgba(46,117,182,0.35)';

      await sleep(300);

      // Fade form out, results in
      formEl.style.opacity = '0';
      await sleep(450);

      resultEl.style.opacity = '1';
      resultEl.style.pointerEvents = 'auto';
      bars.forEach((b, i) => {
        b.style.transitionDelay = `${i * 0.12}s`;
        b.style.width = (b.dataset.w ?? '0') + '%';
      });

      await sleep(3800);

      // Fade results out, reset
      resultEl.style.opacity = '0';
      resultEl.style.pointerEvents = 'none';
      await sleep(450);
    }
  })();
</script>
