---
import BaseLayout from '../layouts/BaseLayout.astro';
import PreviewCard from '../components/PreviewCard.astro';
import { PRICING } from '../config/site';
---

<BaseLayout
  title="Sequel Web Studio"
  description="Sequel Web Studio builds clean, fast websites for small businesses in Northern Tarrant County, TX — starting at $1,000."
>

  <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
  <section class="relative bg-gradient-to-br from-white via-brand-bg to-[#dce8f5] py-20 md:py-28 overflow-hidden">
    <!-- Decorative background blobs for depth -->
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-brand-blue opacity-[0.08] blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 -left-12 w-64 h-64 rounded-full bg-brand-purple opacity-[0.05] blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center relative z-10">
      <span class="badge">Serving Northern Tarrant County, TX</span>
      <h1 class="mt-5 text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy leading-tight max-w-3xl mx-auto">
        Clean, Fast Websites for Small Businesses
      </h1>
      <p class="mt-6 text-xl text-brand-grey max-w-2xl mx-auto leading-relaxed">
        I build new websites and refresh outdated ones — clean, fast, and built to show up wherever your customers are searching: Google, ChatGPT, and voice. Starting at $1,000.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary text-center text-base">Get a Free Website Audit</a>
        <a href="/services" class="btn-secondary text-center text-base">See What's Included</a>
      </div>
    </div>
  </section>

  <!-- Thin purple accent line between sections (D14) -->
  <div class="py-4"><div class="section-divider"></div></div>

  <!-- ══════════════════════════════ VALUE PROPS ══════════════════════════════ -->
  <section class="py-16 bg-gradient-to-b from-brand-bg to-white" aria-labelledby="value-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 id="value-heading" class="text-3xl font-bold text-center text-brand-navy mb-12">
        Why Choose Sequel Web Studio
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="text-center p-8 rounded-2xl bg-white border border-gray-100/60 shadow-[0_4px_24px_rgba(31,56,100,0.06)] hover:shadow-[0_12px_36px_rgba(31,56,100,0.12)] hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-50 to-[#dbeafe] rounded-full flex items-center justify-center mx-auto mb-5 shadow-sm">
            <svg class="w-7 h-7 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-bold text-brand-navy text-lg mb-3">Under 1-Second Load Times</h3>
          <p class="text-brand-grey text-sm leading-relaxed">
            Slow sites lose customers before they even see your offer. Every site I build scores 95+ on Google's speed test — out of the box, on mobile.
          </p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-white border border-gray-100/60 shadow-[0_4px_24px_rgba(31,56,100,0.06)] hover:shadow-[0_12px_36px_rgba(31,56,100,0.12)] hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-50 to-[#dbeafe] rounded-full flex items-center justify-center mx-auto mb-5 shadow-sm">
            <svg class="w-7 h-7 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-brand-navy text-lg mb-3">Found on Google, ChatGPT, and Voice</h3>
          <p class="text-brand-grey text-sm leading-relaxed">
            Every site includes full SEO plus the AI-era signals that get you found when someone asks ChatGPT, Google's AI Overview, or Siri for a business in your area — not just when they type in a search bar.
          </p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-white border border-gray-100/60 shadow-[0_4px_24px_rgba(31,56,100,0.06)] hover:shadow-[0_12px_36px_rgba(31,56,100,0.12)] hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-50 to-[#dbeafe] rounded-full flex items-center justify-center mx-auto mb-5 shadow-sm">
            <svg class="w-7 h-7 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-brand-navy text-lg mb-3">Done-for-You, Start to Finish</h3>
          <p class="text-brand-grey text-sm leading-relaxed">
            No templates, no page builders, no hand-holding required from you. I handle design, build, launch, and post-launch support — you run your business.
          </p>
        </div>

      </div>
    </div>
  </section>

  <div class="py-4"><div class="section-divider"></div></div>

  <!-- ══════════════════════════════ SERVICES / PRICING ══════════════════════ -->
  <section class="py-16 bg-brand-bg" aria-labelledby="services-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="badge">Simple Pricing</span>
        <h2 id="services-heading" class="mt-4 text-3xl font-bold text-brand-navy">
          Two Packages. No Surprises.
        </h2>
        <p class="mt-3 text-brand-grey max-w-xl mx-auto">
          Works for brand-new websites and for refreshing what you already have. Flat-rate — you know the price before we start.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">

        <!-- Starter card -->
        <div class="bg-white rounded-2xl border border-gray-200/70 shadow-[0_4px_24px_rgba(31,56,100,0.08)] hover:shadow-[0_8px_32px_rgba(31,56,100,0.14)] transition-shadow duration-300 p-8 flex flex-col">
          <p class="text-sm font-semibold text-brand-blue uppercase tracking-wider">{PRICING.starter.name}</p>
          <p class="mt-2 text-4xl font-bold text-brand-navy">{PRICING.starter.price}</p>
          <p class="mt-1 text-sm text-brand-grey">{PRICING.starter.tagline}</p>
          <div class="my-6 h-px bg-gray-100"></div>
          <ul class="space-y-3 flex-1">
            {PRICING.starter.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-brand-grey">
                <svg class="w-5 h-5 text-brand-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class="mt-8 block text-center btn-secondary">Get Started</a>
        </div>

        <!-- Premium card (highlighted) -->
        <div class="bg-gradient-to-br from-brand-navy to-[#0F2247] rounded-2xl shadow-[0_12px_48px_rgba(31,56,100,0.4)] p-8 flex flex-col relative overflow-hidden ring-1 ring-white/10">
          <!-- Subtle glow for premium feel -->
          <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-brand-blue opacity-[0.18] blur-2xl pointer-events-none" aria-hidden="true"></div>
          <span class="absolute top-5 right-5 bg-brand-blue text-white text-xs font-semibold px-3 py-1 rounded-full z-10 shadow-sm">
            Most Popular
          </span>
          <p class="text-sm font-semibold text-blue-300 uppercase tracking-wider">{PRICING.premium.name}</p>
          <p class="mt-2 text-4xl font-bold text-white">{PRICING.premium.price}</p>
          <p class="mt-1 text-sm text-blue-200">{PRICING.premium.tagline}</p>
          <div class="my-6 h-px bg-blue-700"></div>
          <ul class="space-y-3 flex-1">
            {PRICING.premium.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-blue-100">
                <svg class="w-5 h-5 text-brand-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a
            href="/contact"
            class="mt-8 block text-center bg-brand-blue text-white px-6 py-3 rounded-lg font-semibold
                   hover:bg-blue-400 transition-colors"
          >
            Get Started
          </a>
        </div>

      </div>
    </div>
  </section>

  <div class="py-4"><div class="section-divider"></div></div>

  <!-- ══════════════════════════════ SOCIAL PROOF ════════════════════════════ -->
  <section class="py-16 bg-white" aria-labelledby="testimonials-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <span class="badge">What Clients Say</span>
      <h2 id="testimonials-heading" class="mt-4 text-3xl font-bold text-brand-navy mb-10">
        Local Businesses Trust Sequel Web Studio
      </h2>
      <!-- Placeholder — real testimonials go here after first projects ship -->
      <div class="max-w-2xl mx-auto bg-white rounded-2xl p-8 text-left border border-gray-100 shadow-[0_8px_32px_rgba(31,56,100,0.08)] relative overflow-hidden">
        <div class="absolute top-2 left-5 text-8xl leading-none text-brand-navy opacity-[0.07] font-serif select-none pointer-events-none" aria-hidden="true">&ldquo;</div>
        <p class="text-brand-grey italic leading-relaxed relative">
          "Testimonial coming soon — first client sites launching shortly."
        </p>
        <div class="mt-5 flex items-center gap-3">
          <div class="w-10 h-10 bg-gray-200 rounded-full flex-shrink-0" aria-hidden="true"></div>
          <div>
            <p class="font-semibold text-brand-navy text-sm">Client name</p>
            <p class="text-xs text-brand-grey">Business — Northern Tarrant County, TX</p>
          </div>
        </div>
      </div>
      <p class="mt-4 text-xs text-gray-400 italic">Real testimonials added after first clients launch</p>
    </div>
  </section>

  <div class="py-4"><div class="section-divider"></div></div>

  <!-- ══════════════════════════════ PORTFOLIO TEASER ══════════════════════════ -->
  <section class="py-16 bg-brand-bg" aria-labelledby="portfolio-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="badge">Recent Work</span>
        <h2 id="portfolio-heading" class="mt-4 text-3xl font-bold text-brand-navy">
          Sites Built by Sequel Web Studio
        </h2>
        <p class="mt-3 text-brand-grey max-w-xl mx-auto">
          Every site is hand-coded from scratch — no templates, no page builders.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <PreviewCard
          url="https://greekcafekeller.com"
          name="Greek Cafe"
          industry="Restaurant"
          description="Fast, clean site for a local Greek café — menu, hours, and a Google Maps presence built to rank."
        />
        <PreviewCard
          url="https://thestraightedgelawns.com"
          name="Lawn Services"
          industry="Lawn & Landscape"
          description="Lead-focused site for a lawn care company — service areas, pricing, and a contact form that converts."
        />
        <PreviewCard
          url="https://cocreator.work"
          name="Garage Epoxy Floors"
          industry="Home Services"
          description="Specialty contractor site with before/after framing, service details, and a clear path to a quote."
        />
      </div>

      <div class="mt-10 text-center">
        <a href="/portfolio" class="btn-secondary inline-block">See All 6 Projects</a>
      </div>
    </div>
  </section>

  <div class="py-4"><div class="section-divider"></div></div>

  <!-- ══════════════════════════════ ABOUT TEASER ════════════════════════════ -->
  <section class="py-16 bg-gradient-to-b from-white to-brand-bg" aria-labelledby="about-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-10">

        <!-- Headshot with gradient border ring -->
        <div class="shrink-0">
          <div class="p-1 rounded-full bg-gradient-to-br from-brand-blue to-brand-navy shadow-[0_12px_40px_rgba(31,56,100,0.25)]">
            <img
              src="/images/joe-headshot.png"
              alt="Joe Weeks, owner of Sequel Web Studio"
              class="w-48 h-48 rounded-full object-cover border-[3px] border-white"
              width="192"
              height="192"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Text -->
        <div>
          <span class="badge">About Joe</span>
          <h2 id="about-heading" class="mt-4 text-3xl font-bold text-brand-navy">
            Hi, I'm Joe Weeks
          </h2>
          <p class="mt-4 text-brand-grey leading-relaxed">
            I kept seeing the same thing happen to small businesses around here — great work, invisible online. Slow sites, bad SEO, and agencies that disappeared after the check cleared. I started Sequel Web Studio to fix that. Every site is hand-coded from scratch: no page builders, no templates, no shortcuts. Fast, clean code that ranks on Google and turns visitors into calls.
          </p>
          <a href="/about" class="mt-5 inline-flex items-center gap-1 text-brand-blue font-semibold hover:underline">
            Read more about me
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ FINAL CTA ═══════════════════════════════ -->
  <section class="relative bg-gradient-to-br from-brand-navy via-[#1e3d7a] to-[#0F2247] py-20 overflow-hidden" aria-labelledby="cta-heading">
    <!-- Decorative light elements -->
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-brand-blue opacity-[0.12] blur-3xl pointer-events-none translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-brand-purple opacity-[0.08] blur-3xl pointer-events-none -translate-x-1/2 translate-y-1/2" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 id="cta-heading" class="text-3xl md:text-4xl font-bold text-white mb-5">
        Ready to Get Your Business Online?
      </h2>
      <p class="text-blue-200 text-lg mb-10 max-w-xl mx-auto">
        Let's build something fast, clean, and built to convert. Get a free website audit — no strings attached.
      </p>
      <a
        href="/contact"
        class="bg-brand-blue text-white px-10 py-4 rounded-lg text-lg font-semibold
               shadow-lg hover:bg-blue-400 hover:shadow-xl transition-all duration-200 inline-block"
      >
        Get a Free Audit
      </a>
    </div>
  </section>

</BaseLayout>
