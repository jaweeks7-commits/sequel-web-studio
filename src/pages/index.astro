    overflow: hidden;
    box-shadow: 0 6px 24px rgba(15,31,61,0.08);
    border: 1px solid #e4eaf5;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .portfolio-screenshot {
    height: 220px;
    overflow: hidden;
    background: #0F1F3D;
