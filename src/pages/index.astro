<script>
  // Hero demo: type URL → press button → fade to results → loop
  (async () => {
    const typedEl  = document.getElementById('hd-typed');
    const btn      = document.getElementById('hd-btn') as HTMLButtonElement;
    const formEl   = document.getElementById('hd-form');
    const resultEl = document.getElementById('hd-result');
    const bars     = Array.from(document.querySelectorAll<HTMLElement>('.hd-bar'));
    if (!typedEl || !btn || !formEl || !resultEl) return;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
    const url = 'mybusiness.com';

    while (true) {
      typedEl.textContent = '';
      formEl.style.opacity = '1';
      resultEl.style.opacity = '0';
      resultEl.style.pointerEvents = 'none';
      bars.forEach(b => { b.style.transitionDelay = '0s'; b.style.width = '0%'; });
      btn.style.transform = '';
      btn.style.boxShadow = '0 4px 14px rgba(46,117,182,0.35)';

      await sleep(900);

      for (const ch of url) {
        typedEl.textContent += ch;
        await sleep(60 + Math.random() * 60);
      }

      await sleep(500);

      btn.style.transform = 'scale(0.92)';
      btn.style.boxShadow = '0 2px 8px rgba(46,117,182,0.15)';
      await sleep(130);
      btn.style.transform = 'scale(1.05)';
      btn.style.boxShadow = '0 8px 24px rgba(46,117,182,0.6)';
      await sleep(110);
      btn.style.transform = 'scale(1)';
      btn.style.boxShadow = '0 4px 14px rgba(46,117,182,0.35)';

      await sleep(300);

      formEl.style.opacity = '0';
      await sleep(450);

      resultEl.style.opacity = '1';
      resultEl.style.pointerEvents = 'auto';
      bars.forEach((b, i) => {
        b.style.transitionDelay = `${i * 0.12}s`;
        b.style.width = (b.dataset.w ?? '0') + '%';
      });

      await sleep(4200);

      resultEl.style.opacity = '0';
      resultEl.style.pointerEvents = 'none';
      await sleep(450);
    }
  })();

  // Lightbox for sample deliverable images
  (() => {
    const lightbox      = document.getElementById('lightbox');
    const img           = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn      = document.getElementById('lightbox-close');
    const captionTitle  = document.getElementById('lightbox-caption-title');
    if (!lightbox || !img || !closeBtn) return;

    document.querySelectorAll<HTMLElement>('[data-lightbox-trigger]').forEach(el => {
      el.addEventListener('click', () => {
        const src   = el.dataset.img   ?? '';
        const label = el.dataset.label ?? '';
        img.src = src;
        img.alt = label;
        if (captionTitle) captionTitle.textContent = label;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
      img.src = '';
      if (captionTitle) captionTitle.textContent = '';
    }

    closeBtn.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  })();

  // Gallery scroll arrows
  (() => {
    const galleryScroll = document.getElementById('homepage-gallery-scroll') as HTMLElement | null;
    const arrowLeft  = document.querySelector<HTMLButtonElement>('.gallery-arrow-dark-left');
    const arrowRight = document.querySelector<HTMLButtonElement>('.gallery-arrow-dark-right');
    const SCROLL_STEP = 232; // 220px thumb + 12px gap

    function updateArrows() {
      if (!galleryScroll || !arrowLeft || !arrowRight) return;
      arrowLeft.style.display  = galleryScroll.scrollLeft > 4 ? 'flex' : 'none';
      arrowRight.style.display = galleryScroll.scrollLeft < galleryScroll.scrollWidth - galleryScroll.clientWidth - 4 ? 'flex' : 'none';
    }

    if (galleryScroll) {
      arrowLeft?.addEventListener('click',  () => { galleryScroll.scrollBy({ left: -SCROLL_STEP, behavior: 'smooth' }); });
      arrowRight?.addEventListener('click', () => { galleryScroll.scrollBy({ left:  SCROLL_STEP, behavior: 'smooth' }); });
      galleryScroll.addEventListener('scroll', updateArrows, { passive: true });
      setTimeout(updateArrows, 100);
    }
  })();

  // Smooth scroll for "get your free score first" link
  document.querySelector<HTMLAnchorElement>('a[href="#free-audit"]')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('free-audit')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
