---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT_EMAIL } from '../config/site';
---

<BaseLayout
  title="Contact — Sequel Web Studio"
  description="Get a free website audit from Sequel Web Studio. Serving small businesses in Northern Tarrant County, TX."
>

  <section class="relative bg-gradient-to-br from-white via-brand-bg to-[#dce8f5] py-20 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-brand-blue opacity-[0.07] blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="max-w-2xl mx-auto">

        <!-- Intro -->
        <div class="text-center mb-10">
          <span class="badge">Let's Talk</span>
          <h1 class="mt-5 text-4xl md:text-5xl font-bold text-brand-navy leading-tight">
            Get a Free Website Audit
          </h1>
          <p class="mt-5 text-xl text-brand-grey leading-relaxed">
            Tell me about your business. I'll take a look at your current site (or your competitors') and give you a straight read on what's working and what isn't — no strings attached.
          </p>
        </div>

        <!-- Success message — shown by JS when ?success=true is in the URL -->
        <div id="success-message" class="hidden bg-green-50 border border-green-200 rounded-2xl p-8 text-center shadow-[0_4px_24px_rgba(31,56,100,0.06)]" role="alert">
          <svg class="w-12 h-12 text-green-500 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h2 class="text-2xl font-bold text-brand-navy mb-2">Message Sent!</h2>
          <p class="text-brand-grey">Thanks — I'll be in touch within one business day.</p>
        </div>

        <!-- Contact form
             Uses Netlify's built-in form handling for Phase 1 (no backend required).
             Phase 2 will replace this with a Netlify Function + Turnstile (decision D10). -->
        <form
          id="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="website-url"
          action="/contact?success=true"
          class="bg-white rounded-2xl border border-gray-100 shadow-[0_8px_32px_rgba(31,56,100,0.08)] p-8 space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <!-- Honeypot — invisible to humans, bots fill it in -->
          <p class="hidden" aria-hidden="true">
            <label>Leave this blank: <input name="website-url" tabindex="-1" autocomplete="off" /></label>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-brand-navy mb-1.5">
                Your Name <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder="Jane Smith"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-brand-navy text-sm
                       focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="business" class="block text-sm font-semibold text-brand-navy mb-1.5">
                Business Name <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                type="text"
                id="business"
                name="business"
                required
                autocomplete="organization"
                placeholder="Smith Plumbing Co."
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-brand-navy text-sm
                       focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-semibold text-brand-navy mb-1.5">
                Email Address <span class="text-red-500" aria-label="required">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="jane@smithplumbing.com"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-brand-navy text-sm
                       focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-brand-navy mb-1.5">
                Phone <span class="text-brand-grey font-normal text-xs">(optional)</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                placeholder="(817) 555-0123"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-brand-navy text-sm
                       focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition"
              />
            </div>
          </div>

          <div>
            <label for="package" class="block text-sm font-semibold text-brand-navy mb-1.5">
              Which package are you considering?
            </label>
            <select
              id="package"
              name="package"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-brand-navy text-sm bg-white
                     focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition"
            >
              <option value="">Not sure yet</option>
              <option value="starter">Starter — $1,000</option>
              <option value="premium">Premium — $2,000</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-brand-navy mb-1.5">
              Tell me about your business <span class="text-red-500" aria-label="required">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              placeholder="What do you do, who are your customers, and what do you want your website to accomplish?"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-brand-navy text-sm resize-none
                     focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition"
            ></textarea>
          </div>

          <button type="submit" class="w-full btn-primary text-center text-base py-3.5">
            Send Message
          </button>

          <p class="text-xs text-center text-brand-grey">
            I typically respond within one business day. Or email me directly at
            <a href={`mailto:${CONTACT_EMAIL}`} class="text-brand-blue hover:underline">{CONTACT_EMAIL}</a>.
          </p>
        </form>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Show success message and hide the form when redirected back with ?success=true
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('success-message')?.classList.remove('hidden');
    document.getElementById('contact-form')?.classList.add('hidden');
  }
</script>
