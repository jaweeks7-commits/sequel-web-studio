---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT_EMAIL, SITE_NAME, SITE_URL } from '../config/site';

const contactSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'ContactPage',
  name:       `Contact ${SITE_NAME}`,
  description: 'Get in touch with Sequel Web Studio for custom website design for small businesses across the US.',
  url:        `${SITE_URL}/contact`,
  mainEntity: {
    '@type':     'ProfessionalService',
    name:        SITE_NAME,
    email:       CONTACT_EMAIL,
    url:         SITE_URL,
  },
});
---

<BaseLayout
  title="Contact"
  description="Start your web design project with Sequel Web Studio. We serve small businesses across the US."
  ogImage="https://sequelwebstudio.com/images/og-home.png"
>
  <script type="application/ld+json" set:html={contactSchema} slot="head" />

  <!-- ── HERO ── -->
  <section style="background: #0F1F3D; padding: 140px 32px 136px; text-align: center; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1;">
      <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Get in Touch</span>
      <h1 style="font-size: clamp(36px, 5vw, 60px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 16px;">
        Let's build something <span class="grad-text">great.</span>
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.55); max-width: 440px; margin: 0 auto;">
        We reply within one business day, usually sooner.
      </p>
    </div>
    <svg viewBox="0 0 1440 60" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;" fill="none">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="#F4F6FB" />
    </svg>
  </section>

  <!-- ── FORM + SIDEBAR ── -->
  <section style="padding: 72px 32px 96px; background: #F4F6FB;">
    <div style="max-width: 1000px; margin: 0 auto; display: flex; gap: 40px; align-items: flex-start; flex-wrap: wrap;">

      <!-- Form card -->
      <div class="reveal" style="flex: 1 1 480px; background: white; border-radius: 20px; border: 1px solid #e4eaf5; box-shadow: 0 8px 32px rgba(15,31,61,0.08); padding: 40px 36px;">

        <!-- Success state — shown when ?success=true -->
        <div id="success-card" class="hidden" role="alert">
          <div style="width: 60px; height: 60px; border-radius: 50%; background: rgba(22,163,74,0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6L9 17l-5-5" />
            </svg>
          </div>
          <h2 style="font-size: 28px; font-weight: 700; color: #0F1F3D; text-align: center; margin-bottom: 8px;">Message sent!</h2>
          <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin: 0 auto 20px;"></div>
          <p style="font-size: 15px; color: #595959; line-height: 1.7; text-align: center;">
            Thanks for reaching out. We'll reply within one business day.
          </p>
        </div>

        <form
          id="contact-form"
          name="contact"
          method="POST"
          netlify
          netlify-honeypot="website-confirm"
          action="/contact?success=true"
          style="display: flex; flex-direction: column; gap: 20px;"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Leave blank: <input name="website-confirm" tabindex="-1" autocomplete="off" /></label>
          </p>

          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <div style="flex: 1 1 180px; display: flex; flex-direction: column; gap: 6px;">
              <label for="name" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">Your Name <span style="color: #DC2626;" aria-label="required">*</span></label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="Jane Smith" class="form-input" />
            </div>
            <div style="flex: 1 1 180px; display: flex; flex-direction: column; gap: 6px;">
              <label for="email" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">Email Address <span style="color: #DC2626;" aria-label="required">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="jane@myshop.com" class="form-input" />
            </div>
          </div>

          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <div style="flex: 1 1 180px; display: flex; flex-direction: column; gap: 6px;">
              <label for="business" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">Business Name</label>
              <input type="text" id="business" name="business" autocomplete="organization" placeholder="Jane's Flower Shop" class="form-input" />
            </div>
            <div style="flex: 1 1 180px; display: flex; flex-direction: column; gap: 6px;">
              <label for="site-url" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">Current Website <span style="font-size: 12px; font-weight: 400; color: #999;">(optional)</span></label>
              <input type="url" id="site-url" name="current-website" placeholder="https://mysite.com" class="form-input" />
            </div>
          </div>

          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <div style="flex: 1 1 180px; display: flex; flex-direction: column; gap: 6px;">
              <label for="platform" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">What platform is your website on? <span style="font-size: 12px; font-weight: 400; color: #999;">(optional)</span></label>
              <select id="platform" name="platform" class="form-input">
                <option value="" disabled selected>Select a platform…</option>
                <option>Wix</option>
                <option>Squarespace</option>
                <option>WordPress</option>
                <option>Shopify</option>
                <option>Custom / HTML</option>
                <option>I don't know</option>
                <option>I don't have a website</option>
              </select>
            </div>
            <div style="flex: 1 1 180px; display: flex; flex-direction: column; gap: 6px;">
              <label for="site-age" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">How old is your website? <span style="font-size: 12px; font-weight: 400; color: #999;">(optional)</span></label>
              <select id="site-age" name="site-age" class="form-input">
                <option value="" disabled selected>Select an age…</option>
                <option>Less than 1 year</option>
                <option>1–3 years</option>
                <option>3–5 years</option>
                <option>5+ years</option>
                <option>Not sure</option>
              </select>
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 6px;">
            <label for="message" style="font-size: 13px; font-weight: 600; color: #0F1F3D;">What do you need? <span style="color: #DC2626;" aria-label="required">*</span></label>
            <textarea id="message" name="message" required rows="5" placeholder="Tell us about your business, what you're looking for, and any questions you have…" class="form-input" style="resize: vertical;"></textarea>
          </div>

          <button type="submit" style="background: linear-gradient(135deg, #1F3864, #2E75B6); color: white; border: none; cursor: pointer; padding: 14px; border-radius: 10px; font-size: 15px; font-weight: 700; font-family: inherit; box-shadow: 0 8px 24px rgba(46,117,182,0.3);">
            Send Message →
          </button>
          <p style="font-size: 12px; color: #999; text-align: center; margin-top: -8px;">
            No spam. We'll reply by email within one business day.
          </p>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="reveal reveal-delay-2 contact-sidebar">
        <div class="info-card">
          <div class="info-card-label">Service area</div>
          <span style="font-size: 14px; color: #595959; line-height: 1.6;">Anywhere in the US. Everything is handled remotely, no in-person meeting required.</span>
        </div>
        <div class="info-card">
          <div class="info-card-label">Response time</div>
          <span style="font-size: 14px; color: #595959;">Within one business day, usually faster.</span>
        </div>
        <div style="background: #0F1F3D; border-radius: 14px; padding: 20px;">
          <div class="info-card-label" style="color: rgba(255,255,255,0.4);">Not ready yet?</div>
          <div style="font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 14px;">Start with a free audit of your current site and see exactly what needs fixing.</div>
          <a href="/contact" style="display: inline-block; background: linear-gradient(135deg,#2E75B6,#8E44AD); color: white; border-radius: 8px; padding: 9px 16px; font-size: 13px; font-weight: 600; text-decoration: none;">
            Tell us about your site
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .form-input {
    padding: 11px 14px;
    border-radius: 9px;
    border: 1.5px solid #d0d9e8;
    font-size: 14px;
    font-family: inherit;
    outline: none;
    color: #595959;
    background: #FAFBFE;
    width: 100%;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-input:focus {
    border-color: #2E75B6;
    box-shadow: 0 0 0 3px rgba(46,117,182,0.12);
  }
  select.form-input {
    cursor: pointer;
    appearance: auto;
    color: #595959;
  }
  select.form-input option[value=""] { color: #8892A0; }
  .info-card {
    background: white;
    border-radius: 14px;
    border: 1px solid #e4eaf5;
    padding: 18px 20px;
    margin-bottom: 14px;
  }
  .info-card-label {
    font-size: 10px;
    font-weight: 700;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 8px;
  }
  .contact-sidebar {
    flex: 0 1 260px;
    display: flex;
    flex-direction: column;
  }
  .hidden {
    display: none;
  }
  @media (max-width: 640px) {
    .contact-sidebar {
      flex: 1 1 100%;
    }
  }
</style>

<script>
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('success-card')?.classList.remove('hidden');
    document.getElementById('contact-form')?.classList.add('hidden');
  }
</script>
