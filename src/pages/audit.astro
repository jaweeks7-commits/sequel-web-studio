  .sample-thumb:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(15,31,61,0.15);
  }
</style>

<script>import '../scripts/accordion';</script>

<script>
  // ── Page-load: handle Stripe redirect params ────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const orderStatus = params.get('order');

  if (orderStatus === 'success' || orderStatus === 'cancelled') {
    const ctaArea = document.getElementById('order-cta-area');
    const wrapper = document.getElementById('order-form-wrapper');
    const section = document.getElementById('order-section');
    if (ctaArea) ctaArea.style.display = 'none';
    if (wrapper) {
      wrapper.style.display = 'block';
      if (orderStatus === 'success') {
        wrapper.innerHTML = `
          <div style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); border-radius: 16px; padding: 32px; text-align: center;">
            <div style="font-size: 32px; margin-bottom: 16px;">&#10003;</div>
            <h3 style="color: white; font-size: 20px; font-weight: 700; margin: 0 0 12px; letter-spacing: -0.3px;">Payment confirmed — you're in.</h3>
            <p style="font-size: 15px; color: rgba(255,255,255,0.75); line-height: 1.65; margin: 0;">
              Check your email for an order confirmation. Your Pro Diagnosis + Remedy Package will be delivered within 24 hours.
            </p>
          </div>`;
      } else {
        wrapper.innerHTML = `
          <div style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); border-radius: 16px; padding: 32px; text-align: center;">
            <p style="font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.65; margin: 0 0 16px;">
              No problem — your card wasn&rsquo;t charged. Ready when you are.
            </p>
            <button
              onclick="document.getElementById('order-cta-area')!.style.display='block';document.getElementById('order-form-wrapper')!.style.display='none';"
              style="padding: 12px 24px; border-radius: 8px; background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2); cursor: pointer; font-family: inherit; font-size: 14px;"
            >Try again &rarr;</button>
          </div>`;
      }
    }
    if (section) setTimeout(() => section.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
    window.history.replaceState({}, '', '/audit');
  }

  // ── Reveal order form on CTA click ──────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-order-cta]').forEach(btn => {
    btn.addEventListener('click', () => {
      const wrapper = document.getElementById('order-form-wrapper');
      const ctaArea = document.getElementById('order-cta-area');
      if (wrapper && ctaArea) {
        ctaArea.style.display = 'none';
        wrapper.style.display = 'block';
        wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ── Form submit → Stripe Checkout ────────────────────────────────────────
  const orderForm = document.getElementById('order-form') as HTMLFormElement | null;
  orderForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot — bots fill hidden fields
    const botField = orderForm.querySelector<HTMLInputElement>('[name="bot-field"]');
    if (botField?.value) return;

    const submitBtn = document.getElementById('order-submit-btn') as HTMLButtonElement | null;
    const errorEl   = document.getElementById('order-form-error') as HTMLParagraphElement | null;
    if (submitBtn) { submitBtn.textContent = 'Redirecting to payment…'; submitBtn.disabled = true; }
    if (errorEl)   { errorEl.style.display = 'none'; }

    const payload = {
      name:     (orderForm.querySelector<HTMLInputElement>('[name="name"]')?.value     ?? '').trim(),
      business: (orderForm.querySelector<HTMLInputElement>('[name="business"]')?.value ?? '').trim(),
      url:      (() => { let v = (orderForm.querySelector<HTMLInputElement>('[name="url"]')?.value ?? '').trim(); if (v && !/^https?:\/\//i.test(v)) v = 'https://' + v; return v; })(),
      email:    (orderForm.querySelector<HTMLInputElement>('[name="email"]')?.value     ?? '').trim(),
      notes:    (orderForm.querySelector<HTMLTextAreaElement>('[name="notes"]')?.value  ?? '').trim(),
    };

    try {
      const res  = await fetch('/.netlify/functions/create-checkout-session', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });
      const json = await res.json() as { checkoutUrl?: string; error?: string };
      if (json.checkoutUrl) {
        window.location.href = json.checkoutUrl;
      } else {
        throw new Error(json.error ?? 'Unknown error');
      }
    } catch (err) {
      if (submitBtn) { submitBtn.textContent = 'Submit Your Audit Request →'; submitBtn.disabled = false; }
      const msg = (err instanceof Error && err.message && err.message !== 'Unknown error') ? err.message : 'Something went wrong — please try again or email us directly.';
      if (errorEl)   { errorEl.textContent = msg; errorEl.style.display = 'block'; }
    }
  });
</script>

<script>
  // ── Deliverable gallery lightbox ─────────────────────────────────────────
  const dlLightbox      = document.getElementById('deliverable-lightbox')    as HTMLElement | null;
  const dlImg           = document.getElementById('lightbox-img')             as HTMLImageElement | null;
  const dlCaptionTitle  = document.getElementById('lightbox-caption-title')   as HTMLElement | null;
  const dlClose         = document.getElementById('lightbox-close');

  if (dlLightbox) {
    const openLightbox  = (src: string, alt: string) => {
      if (dlImg)          { dlImg.src = src; dlImg.alt = alt; }
      if (dlCaptionTitle) { dlCaptionTitle.textContent = alt; }
      dlLightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    };
    const closeLightbox = () => {
      dlLightbox.style.display = 'none';
      document.body.style.overflow = '';
    };
    document.querySelectorAll<HTMLImageElement>('.sample-thumb').forEach(img => {
      img.addEventListener('click', () => openLightbox(img.dataset.deliverableSrc ?? img.src, img.alt));
    });
    dlLightbox.addEventListener('click', closeLightbox);
    dlClose?.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  }

  // ── Gallery scroll arrows ─────────────────────────────────────────────────
  const galleryScroll = document.getElementById('deliverable-gallery-scroll') as HTMLElement | null;
  const arrowLeft  = document.querySelector<HTMLButtonElement>('.gallery-arrow-left');
  const arrowRight = document.querySelector<HTMLButtonElement>('.gallery-arrow-right');
  const SCROLL_STEP = 212; // 200px thumb + 12px gap

  function updateArrows() {
    if (!galleryScroll || !arrowLeft || !arrowRight) return;
    arrowLeft.style.display  = galleryScroll.scrollLeft > 4 ? 'flex' : 'none';
    arrowRight.style.display = galleryScroll.scrollLeft < galleryScroll.scrollWidth - galleryScroll.clientWidth - 4 ? 'flex' : 'none';
  }

  if (galleryScroll) {
    arrowLeft?.addEventListener('click',  () => { galleryScroll.scrollBy({ left: -SCROLL_STEP, behavior: 'smooth' }); });
    arrowRight?.addEventListener('click', () => { galleryScroll.scrollBy({ left:  SCROLL_STEP, behavior: 'smooth' }); });
    galleryScroll.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  }
</script>
