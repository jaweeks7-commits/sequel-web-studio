---
import BaseLayout from '../layouts/BaseLayout.astro';
import PreviewCard from '../components/PreviewCard.astro';

const projects = [
  {
    url: 'https://greekcafekeller.com',
    name: 'Greek Cafe',
    industry: 'Restaurant',
    description: 'Menu, hours, and location for a local Greek café — built to rank for "Greek food near me" and show up in voice and AI searches.',
  },
  {
    url: 'https://thestraightedgelawns.com',
    name: 'Lawn Services',
    industry: 'Lawn & Landscape',
    description: 'Service-area-focused site for a lawn care company — clear pricing, service details, and a contact form designed to convert visitors into booked jobs.',
  },
  {
    url: 'https://proposedwebsite.com',
    name: 'Thai Restaurant',
    industry: 'Restaurant',
    description: 'Clean, image-forward site for a Thai restaurant — menu presentation, hours, and a Google Maps presence optimized for local search.',
  },
  {
    url: 'https://cocreator.dev',
    name: 'Donut Shop',
    industry: 'Bakery & Café',
    description: 'Bright, fast-loading site for a local donut shop — daily specials, hours, and a location page built to capture foot traffic from search.',
  },
  {
    url: 'https://cocreator.work',
    name: 'Garage Epoxy Floors',
    industry: 'Home Services',
    description: 'Specialty contractor site with before/after framing, service options, and a quote request form — built for homeowners actively comparing vendors.',
  },
  {
    url: 'https://co-creating.live',
    name: 'Sod Laying',
    industry: 'Lawn & Landscape',
    description: 'Lead-generation site for a sod installation service — service area, project types, and a direct path to a free estimate.',
  },
];
---

<BaseLayout
  title="Portfolio — Sequel Web Studio"
  description="Hand-coded websites built by Sequel Web Studio for small businesses in Northern Tarrant County, TX. Every site is fast, clean, and built to rank."
>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-white via-brand-bg to-[#dce8f5] py-20 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-brand-blue opacity-[0.07] blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center relative z-10">
      <span class="badge">Our Work</span>
      <h1 class="mt-5 text-4xl md:text-5xl font-bold text-brand-navy leading-tight">
        Sites Built by Sequel Web Studio
      </h1>
      <p class="mt-6 text-xl text-brand-grey max-w-2xl mx-auto leading-relaxed">
        Every site is hand-coded from scratch — no templates, no page builders. Hover any card to scroll through the full site.
      </p>
    </div>
  </section>

  <!-- Project grid -->
  <section class="py-16 bg-white" aria-labelledby="projects-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 id="projects-heading" class="sr-only">All projects</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(project => (
          <PreviewCard
            url={project.url}
            name={project.name}
            industry={project.industry}
            description={project.description}
            large={true}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-gradient-to-br from-brand-navy via-[#1e3d7a] to-[#0F2247] py-20 overflow-hidden" aria-labelledby="portfolio-cta-heading">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-brand-blue opacity-[0.12] blur-3xl pointer-events-none translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-brand-purple opacity-[0.08] blur-3xl pointer-events-none -translate-x-1/2 translate-y-1/2" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 id="portfolio-cta-heading" class="text-3xl md:text-4xl font-bold text-white mb-5">
        Want a Site Like These?
      </h2>
      <p class="text-blue-200 text-lg mb-10 max-w-xl mx-auto">
        Get a free audit of your current site — or tell me about your business and I'll show you what's possible.
      </p>
      <a
        href="/contact"
        class="bg-brand-blue text-white px-10 py-4 rounded-lg text-lg font-semibold
               shadow-lg hover:bg-blue-400 hover:shadow-xl transition-all duration-200 inline-block"
      >
        Get a Free Audit
      </a>
    </div>
  </section>

</BaseLayout>
