---
import BaseLayout from '../layouts/BaseLayout.astro';

// Design width the iframes are sized for — matches typical desktop viewport
const IFRAME_WIDTH = 1440;

const projects = [
  {
    url: 'https://greekcafekeller.com',
    name: 'Greek Cafe',
    industry: 'Restaurant',
    description: 'Menu, hours, and location for a local Greek café — built to rank for "Greek food near me" and show up in voice and AI searches.',
  },
  {
    url: 'https://thestraightedgelawns.com',
    name: 'Lawn Services',
    industry: 'Lawn & Landscape',
    description: 'Service-area-focused site for a lawn care company — clear pricing, service details, and a contact form designed to convert visitors into booked jobs.',
  },
  {
    url: 'https://proposedwebsite.com',
    name: 'Thai Restaurant',
    industry: 'Restaurant',
    description: 'Clean, image-forward site for a Thai restaurant — menu presentation, hours, and a Google Maps presence optimized for local search.',
  },
  {
    url: 'https://cocreator.dev',
    name: 'Donut Shop',
    industry: 'Bakery & Café',
    description: 'Bright, fast-loading site for a local donut shop — daily specials, hours, and a location page built to capture foot traffic from search.',
  },
  {
    url: 'https://cocreator.work',
    name: 'Garage Epoxy Floors',
    industry: 'Home Services',
    description: 'Specialty contractor site with before/after framing, service options, and a quote request form — built for homeowners actively comparing vendors.',
  },
  {
    url: 'https://co-creating.live',
    name: 'Sod Laying',
    industry: 'Lawn & Landscape',
    description: 'Lead-generation site for a sod installation service — service area, project types, and a direct path to a free estimate.',
  },
];
---

<BaseLayout
  title="Portfolio — Sequel Web Studio"
  description="Hand-coded websites built by Sequel Web Studio for small businesses in Northern Tarrant County, TX. Every site is fast, clean, and built to rank."
>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-white via-brand-bg to-[#dce8f5] py-20 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-brand-blue opacity-[0.07] blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center relative z-10">
      <span class="badge">Our Work</span>
      <h1 class="mt-5 text-4xl md:text-5xl font-bold text-brand-navy leading-tight">
        Sites Built by Sequel Web Studio
      </h1>
      <p class="mt-6 text-xl text-brand-grey max-w-2xl mx-auto leading-relaxed">
        Every site is hand-coded from scratch — no templates, no page builders. Hover any card to scroll through the full site.
      </p>
    </div>
  </section>

  <!-- Project grid -->
  <section class="py-16 bg-white" aria-labelledby="projects-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 id="projects-heading" class="sr-only">All projects</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(project => (
          <div
            class="group rounded-2xl border border-gray-100/60 shadow-[0_4px_24px_rgba(31,56,100,0.06)] hover:shadow-[0_12px_36px_rgba(31,56,100,0.12)] transition-shadow duration-300 overflow-hidden flex flex-col bg-white"
            data-card
          >
            <!-- Live preview window -->
            <div
              class="preview-container relative overflow-hidden bg-brand-bg shrink-0"
              data-preview-container
              aria-hidden="true"
            >
              <div class="preview-scaler" data-scaler style="transform-origin: top left; will-change: transform;">
                <iframe
                  src={project.url}
                  width={IFRAME_WIDTH}
                  height="3600"
                  loading="lazy"
                  scrolling="no"
                  tabindex="-1"
                  title={`Live preview of ${project.name}`}
                  style="display:block; border:none; pointer-events:none; user-select:none;"
                ></iframe>
              </div>
              <!-- Subtle gradient fade at the bottom of the preview -->
              <div class="absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-white/60 to-transparent pointer-events-none"></div>
            </div>

            <!-- Card content -->
            <div class="p-6 flex flex-col flex-1">
              <span class="text-xs font-semibold text-brand-blue uppercase tracking-wider">{project.industry}</span>
              <h3 class="mt-2 text-lg font-bold text-brand-navy">{project.name}</h3>
              <p class="mt-2 text-sm text-brand-grey leading-relaxed flex-1">{project.description}</p>
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-brand-blue hover:underline"
              >
                View Site
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-gradient-to-br from-brand-navy via-[#1e3d7a] to-[#0F2247] py-20 overflow-hidden" aria-labelledby="portfolio-cta-heading">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-brand-blue opacity-[0.12] blur-3xl pointer-events-none translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-brand-purple opacity-[0.08] blur-3xl pointer-events-none -translate-x-1/2 translate-y-1/2" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 id="portfolio-cta-heading" class="text-3xl md:text-4xl font-bold text-white mb-5">
        Want a Site Like These?
      </h2>
      <p class="text-blue-200 text-lg mb-10 max-w-xl mx-auto">
        Get a free audit of your current site — or tell me about your business and I'll show you what's possible.
      </p>
      <a
        href="/contact"
        class="bg-brand-blue text-white px-10 py-4 rounded-lg text-lg font-semibold
               shadow-lg hover:bg-blue-400 hover:shadow-xl transition-all duration-200 inline-block"
      >
        Get a Free Audit
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .preview-container {
    height: 260px;
  }
</style>

<script>
  const IFRAME_WIDTH  = 1440;  // must match the width attribute on the iframes
  const SCROLL_AMOUNT = 2400;  // original-px to scroll through on hover
  const FWD_DURATION  = 9000;  // ms to reach bottom
  const REV_DURATION  = 1000;  // ms to snap back on leave

  document.querySelectorAll<HTMLElement>('[data-card]').forEach(card => {
    const container = card.querySelector<HTMLElement>('[data-preview-container]')!;
    const scaler    = card.querySelector<HTMLElement>('[data-scaler]')!;

    let raf: number | null = null;
    let currentY  = 0;   // current scroll offset in original px
    let animFrom  = 0;
    let animTo    = 0;
    let animDur   = 0;
    let animStart = 0;

    function scale() {
      return container.offsetWidth / IFRAME_WIDTH;
    }

    function paint() {
      scaler.style.transform = `scale(${scale()}) translateY(${-currentY}px)`;
    }

    function easeInOut(t: number) {
      return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
    }

    function easeOut(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    function startAnim(from: number, to: number, dur: number, easeFn: (t: number) => number) {
      if (raf) cancelAnimationFrame(raf);
      animFrom  = from;
      animTo    = to;
      animDur   = dur;
      animStart = 0;

      function tick(ts: number) {
        if (!animStart) animStart = ts;
        const t     = Math.min((ts - animStart) / animDur, 1);
        currentY    = animFrom + (animTo - animFrom) * easeFn(t);
        paint();
        if (t < 1) raf = requestAnimationFrame(tick);
      }
      raf = requestAnimationFrame(tick);
    }

    // Set initial scale without animation
    paint();

    card.addEventListener('mouseenter', () => {
      startAnim(currentY, SCROLL_AMOUNT, FWD_DURATION, easeInOut);
    });

    card.addEventListener('mouseleave', () => {
      startAnim(currentY, 0, REV_DURATION, easeOut);
    });

    // Keep scale correct after resize
    window.addEventListener('resize', paint, { passive: true });
  });
</script>
