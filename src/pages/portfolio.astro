---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PORTFOLIO } from '../data/portfolio';
---

<BaseLayout
  title="Portfolio"
  description="Custom-coded websites built by Sequel Web Studio for small businesses across the US. Every site is fast, clean, and built to rank."
  ogImage="https://sequelwebstudio.com/images/og-home.png"
>

  <!-- ── HERO ── -->
  <section style="background: #0F1F3D; padding: 140px 32px 136px; text-align: center; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1;">
      <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Our Work</span>
      <h1 style="font-size: clamp(36px, 5vw, 60px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 16px;">
        Sites built by <span class="grad-text">Sequel Web Studio.</span>
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.55); max-width: 480px; margin: 0 auto;">
        Every site is custom-coded from scratch — no templates, no page builders.
      </p>
    </div>
    <svg viewBox="0 0 1440 60" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;" fill="none">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="#F4F6FB" />
    </svg>
  </section>

  <!-- ── GRID ── -->
  <section style="padding: 72px 32px 96px; background: #F4F6FB;">
    <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 28px;">
      {PORTFOLIO.map((site, i) => (
        <a
          href={site.href}
          target={site.external ? '_blank' : undefined}
          rel={site.external ? 'noopener noreferrer' : undefined}
          class={`reveal reveal-delay-${(i % 3) + 1} hover-card portfolio-card`}
          style="background: white; border-radius: 16px; border: 1px solid #e4eaf5; box-shadow: 0 4px 20px rgba(15,31,61,0.07); overflow: hidden; text-decoration: none; display: block;"
        >
          <div class="portfolio-screenshot">
            <img src={site.img} alt={`${site.name} ${site.tag.toLowerCase()} website built by Sequel Web Studio`} class="portfolio-img" loading="lazy" />
          </div>
          <div style="padding: 18px 20px;">
            <div style="font-size: 11px; font-weight: 600; color: #2E75B6; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">{site.tag}</div>
            <div style="font-size: 16px; font-weight: 700; color: #0F1F3D; margin-bottom: 6px;">{site.url}</div>
            <div style="font-size: 13px; color: #595959; line-height: 1.6;">{site.description}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── CTA ── -->
  <section style="background: linear-gradient(135deg, #1F3864 0%, #2E75B6 60%, #8E44AD 100%); padding: 80px 32px; text-align: center;">
    <h2 style="font-size: 32px; font-weight: 700; color: white; letter-spacing: -0.5px; margin-bottom: 16px;">Want a site like these?</h2>
    <p style="font-size: 16px; color: rgba(255,255,255,0.55); max-width: 440px; margin: 0 auto 32px;">
      Get a free audit of your current site — or tell us about your business and we'll show you what's possible.
    </p>
    <a href="/contact" style="background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 13px 32px; border-radius: 10px; font-size: 15px; font-weight: 700; text-decoration: none; display: inline-block; box-shadow: 0 8px 24px rgba(46,117,182,0.4);">
      Get in touch →
    </a>
  </section>

</BaseLayout>

<style>
  .portfolio-screenshot {
    height: 220px;
    overflow: hidden;
    background: #0F1F3D;
  }
  .portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s ease;
  }
  .portfolio-card:hover .portfolio-img {
    transform: scale(1.04) translateY(-2%);
  }
</style>
