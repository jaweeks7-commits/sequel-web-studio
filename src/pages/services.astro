---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_URL } from '../config/site';
import { layers } from '../data/layers';
import { PORTFOLIO } from '../data/portfolio';

const offerSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'ProfessionalService',
  name:       SITE_NAME,
  url:        SITE_URL,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name:    'Web Design Services',
    itemListElement: [
      {
        '@type':       'Offer',
        name:          'Create New Site',
        description:   'Complete website built from scratch — design, build, launch, and 30 days of post-launch support.',
        price:         '1000',
        priceCurrency: 'USD',
        seller:        { '@type': 'ProfessionalService', name: SITE_NAME },
      },
      {
        '@type':       'Offer',
        name:          'Modernize Existing Site',
        description:   'Full audit and rebuild of your existing website on a modern eight-layer technical foundation.',
        price:         '1000',
        priceCurrency: 'USD',
        seller:        { '@type': 'ProfessionalService', name: SITE_NAME },
      },
    ],
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: "What's included in the price?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Design, build, launch, and the full technical foundation — schema markup, sitemap, analytics setup, contact form, and 30 days of post-launch support.',
      },
    },
    {
      '@type': 'Question',
      name: 'What about hosting?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We handle hosting for $20/month. That covers your server, SSL certificate, and uptime monitoring — no setup required on your end.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does it take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most sites launch in 2–3 weeks, depending on how quickly content is available.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you do ongoing updates?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Future support is available at a rate of $60/hour with a half-hour minimum.',
      },
    },
  ],
});
---

<BaseLayout
  title="Web Design Services"
  description="Two paths, one price. Sequel Web Studio builds custom websites for small businesses — new sites and modernizations starting at $1,000."
  ogImage="https://sequelwebstudio.com/images/og-home.png"
>
  <script type="application/ld+json" set:html={offerSchema} slot="head" />
  <script type="application/ld+json" set:html={faqSchema} slot="head" />

  <!-- ── HERO ── -->
  <section style="background: #0F1F3D; padding: 140px 32px 136px; text-align: center; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1; max-width: 680px; margin: 0 auto;">
      <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Services &amp; Pricing</span>
      <h1 style="font-size: clamp(36px, 5vw, 64px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 16px;">
        Beautiful, performant websites.<br /><span class="grad-text">One-time build price.</span>
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.55); max-width: 480px; margin: 0 auto;">
        One flat fee to design, build, and launch. Then $20/month for hosting.
      </p>
    </div>
    <svg viewBox="0 0 1440 60" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;" fill="none">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="#F4F6FB" />
    </svg>
  </section>

  <!-- ── AUDIT BRIDGE ── -->
  <section style="background: #F4F6FB; padding: 20px 32px; border-bottom: 1px solid #e4eaf5;">
    <div style="max-width: 1160px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap;">
      <p style="font-size: 15px; color: #595959; margin: 0; line-height: 1.5;">
        <strong style="color: #0F1F3D;">Not sure which path is right for you?</strong>
        &nbsp;Our $350 Pro Diagnosis + Remedy Package tells you exactly what your site needs, before you spend a dollar on a rebuild.
      </p>
      <a href="/audit#order" style="flex-shrink: 0; background: linear-gradient(135deg, #00bcd4, #0097a7); color: white; padding: 10px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; text-decoration: none; white-space: nowrap; box-shadow: 0 4px 14px rgba(0,188,212,0.3);">
        Get Your Pro Diagnosis — $350 →
      </a>
    </div>
  </section>

  <!-- ── PRICING ── -->
  <section style="padding: 96px 0; background: white;">
    <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 980px; margin-bottom: 56px;">
        <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6;">Pricing</span>
        <h2 style="font-size: clamp(28px, 4vw, 48px); font-weight: 700; color: #0F1F3D; letter-spacing: -1px; line-height: 1.12; margin-top: 12px; margin-bottom: 8px;">
          One price to start. No surprises.
        </h2>
        <p style="font-size: 18px; font-weight: 600; color: #595959; margin-bottom: 16px;">Two paths, same starting price.</p>
        <p style="font-size: 16px; color: #595959; line-height: 1.7;">
          Most small-business websites start at $1,000 flat — including design, build, launch, and the full technical foundation. Hosting is $20/month. If your business needs something beyond the standard build — additional pages, a custom integration — we quote those separately, up front, in plain English.
        </p>
      </div>

      <div style="display: flex; gap: 28px; justify-content: center; flex-wrap: wrap; align-items: stretch;">

        <!-- New Site card -->
        <div class="reveal reveal-delay-1 hover-card" style="flex: 1 1 380px; max-width: 480px; background: white; border-radius: 20px; padding: 40px 36px; border: 2px solid #b8cce0; box-shadow: 0 8px 32px rgba(15,31,61,0.1);">
          <div style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6; margin-bottom: 12px;">Starting fresh</div>
          <div style="font-size: 26px; font-weight: 700; color: #0F1F3D; letter-spacing: -0.5px; margin-bottom: 14px;">Create New Site</div>
          <p style="font-size: 14px; color: #595959; line-height: 1.65; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #e4eaf5;">
            For businesses whose online presence is a Facebook page, an Instagram bio, or a Google Business Profile, but not a real website.
          </p>
          <div style="font-size: 52px; font-weight: 700; color: #0F1F3D; letter-spacing: -2px; line-height: 1;">$1,000</div>
          <div style="font-size: 13px; color: #999; margin-top: 4px; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid #e4eaf5;">Starting price · one-time fee</div>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px;">
            {[
              'Complete site built from scratch — homepage, services, about, contact, privacy, 404, and more',
              'All six technical layers included',
              'Domain setup, SSL, launch',
              '30 days of post-launch support',
              '$20/month hosting after launch',
              'Future support: $60/hr, half-hour minimum',
            ].map(f => (
              <li style="display: flex; gap: 10px; font-size: 14px; color: #595959; line-height: 1.4; align-items: flex-start;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;">
                  <circle cx="8" cy="8" r="7" fill="rgba(46,117,182,0.1)" />
                  <path d="M5 8l2 2 4-4" stroke="#2E75B6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" style="display: block; padding: 13px; border-radius: 10px; font-size: 14px; font-weight: 700; text-align: center; text-decoration: none; color: #1F3864; border: 2px solid #1F3864; background: transparent;">
            Let's Talk About a New Site
          </a>
        </div>

        <!-- Modernize card -->
        <div class="reveal reveal-delay-2 hover-card" style="flex: 1 1 380px; max-width: 480px; background: #0F1F3D; border-radius: 20px; padding: 40px 36px; box-shadow: 0 20px 56px rgba(15,31,61,0.25); position: relative;">
          <div style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; font-size: 11px; font-weight: 700; padding: 5px 18px; border-radius: 9999px; white-space: nowrap;">Most Popular</div>
          <div style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4; margin-bottom: 12px;">Existing site</div>
          <div style="font-size: 26px; font-weight: 700; color: white; letter-spacing: -0.5px; margin-bottom: 14px;">Modernize Existing</div>
          <p style="font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.65; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1);">
            For businesses whose current website is five-plus years old, hosted on a dated template, or invisible to AI assistants and voice search.
          </p>
          <div style="font-size: 52px; font-weight: 700; color: white; letter-spacing: -2px; line-height: 1;">$1,000</div>
          <div style="font-size: 13px; color: rgba(255,255,255,0.35); margin-top: 4px; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.1);">Starting price · one-time fee</div>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px;">
            {[
              "Full audit of your current site — what's working, what's broken, what's invisible",
              'Your content preserved and restructured so AI can actually read it',
              'Rebuild on the same eight-layer foundation',
              'Launch on your existing domain — your URLs, your SEO, no lost traffic',
              '30 days of post-launch support',
              '$20/month hosting after launch',
              'Future support: $60/hr, half-hour minimum',
            ].map(f => (
              <li style="display: flex; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.4; align-items: flex-start;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;">
                  <circle cx="8" cy="8" r="7" fill="rgba(75,159,212,0.2)" />
                  <path d="M5 8l2 2 4-4" stroke="#4B9FD4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" style="display: block; padding: 13px; border-radius: 10px; font-size: 14px; font-weight: 700; text-align: center; text-decoration: none; color: white; background: linear-gradient(135deg, #2E75B6, #8E44AD); box-shadow: 0 8px 24px rgba(46,117,182,0.35);">
            Start With a Free Audit
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── THE FIX ── -->
  <section style="padding: 96px 0 152px; background: linear-gradient(135deg, #0F1F3D 0%, #1F3864 60%, #2E75B6 100%); position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0; opacity: 0.3;"></div>
    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 800px; margin-bottom: 52px;">
        <span style="font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #16A34A;">What We Build In</span>
        <h2 style="font-size: clamp(30px, 4vw, 50px); font-weight: 700; color: white; letter-spacing: -1.2px; line-height: 1.12; margin-top: 12px; margin-bottom: 20px;">Websites built for the way search works now.</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.62); line-height: 1.72;">
          Whether we modernize your existing site or build from scratch, every project is engineered to be found by ChatGPT, Perplexity, voice assistants, and Google AI Overviews, not just traditional search.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
        {[
          {
            num: '01',
            title: 'We make your site readable by AI assistants.',
            body: "ChatGPT, Claude, and Gemini pull from sites with clean, structured content. We build yours with semantic HTML and schema.org data so AI tools can find, quote, and recommend you, instead of a competitor.",
          },
          {
            num: '02',
            title: 'We structure your content for voice and assistant search.',
            body: "Getting picked by Siri or Alexa isn't random. It requires clean schema data, a tight Google Business Profile, and FAQ content written the way people speak. We build all of that in from day one.",
          },
          {
            num: '03',
            title: "We help Google's AI include you, not bypass you.",
            body: "Google's AI Overviews pull from sites with structured, machine-readable content. We make sure yours qualifies, so when someone searches your category, your business is part of the answer.",
          },
        ].map((card, i) => (
          <div class={`reveal reveal-delay-${i + 1} hover-card`} style="background: rgba(255,255,255,0.07); border-radius: 18px; padding: 32px 28px; border: 1px solid rgba(255,255,255,0.12);">
            <div style="font-size: 12px; font-family: 'Space Mono', monospace; color: #16A34A; letter-spacing: 1px; margin-bottom: 16px;">{card.num}</div>
            <h3 style="font-size: 19px; font-weight: 700; color: white; line-height: 1.3; letter-spacing: -0.3px; margin-bottom: 12px;">{card.title}</h3>
            <p style="font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.68;">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="#0F1F3D" />
    </svg>
  </section>

  <!-- ── TECHNICAL FOUNDATION ── -->
  <section style="padding: 96px 0; background: #0F1F3D; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="max-width: 680px; margin-bottom: 52px;">
        <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">The Technical Foundation</span>
        <h2 style="font-size: clamp(28px, 4vw, 48px); font-weight: 700; color: white; letter-spacing: -1px; line-height: 1.12; margin-top: 12px; margin-bottom: 16px;">
          Most designers stop at the pretty. We don't.
        </h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.6); line-height: 1.72;">
          Every Sequel Web Studio site, whether new or modernized, is built across eight technical categories. This is what separates a site that looks good from a site that actually gets found, converts visitors into customers, and keeps working five years from now. We build for conversion and longevity from day one, not as an afterthought.
        </p>
      </div>

      <!-- Accordion -->
      <div class="layers-dark reveal accordion" data-accordion>
        {layers.map((layer, i) => (
          <div class="acc-item" data-acc-item>
            <button class="acc-header" data-acc-btn type="button" aria-expanded="false" aria-controls={`svc-acc-body-${i}`}>
              <span class="acc-num">{layer.num}</span>
              <span class="acc-meta">
                <span class="acc-title">{layer.title}</span>
                <span class="acc-sub">{layer.sub}</span>
              </span>
              <span class="acc-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <line x1="7" y1="0" x2="7" y2="14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <line x1="0" y1="7" x2="14" y2="7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
            <div class="acc-body" data-acc-body id={`svc-acc-body-${i}`}>
              <ul class="acc-list">
                {layer.items.map(item => (
                  <li class="acc-list-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;">
                      <circle cx="8" cy="8" r="7" fill="rgba(75,159,212,0.2)" />
                      <path d="M5 8l2 2 4-4" stroke="#4B9FD4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <!-- Callout bar -->
      <div class="reveal" style="margin-top: 28px; background: rgba(255,255,255,0.06); border-radius: 14px; border: 2px solid rgba(255,255,255,0.12); padding: 24px 28px; display: flex; align-items: center; gap: 16px;">
        <div style="width: 3px; height: 48px; background: #8E44AD; border-radius: 9999px; flex-shrink: 0;"></div>
        <p style="font-size: 16px; font-weight: 500; color: white; line-height: 1.55; margin: 0;">
          When a graphic designer builds you a website, you get the first layer. When we build you a website, you get all eight.
        </p>
      </div>

    </div>
  </section>

  <!-- ── FAQ ── -->
  <section style="padding: 80px 32px 96px; background: #F4F6FB;">
    <div style="max-width: 900px; margin: 0 auto;">
      <div class="reveal">
        <h2 style="font-size: 28px; font-weight: 700; color: #0F1F3D; letter-spacing: -0.5px; margin-bottom: 8px; text-align: center;">Common Questions</h2>
        <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin: 0 auto 36px;"></div>
        <div class="faq-grid">
          {[
            ["What's included in the price?", 'Design, build, launch, and the full technical foundation — schema markup, sitemap, analytics setup, contact form, and 30 days of post-launch support.'],
            ['What about hosting?', 'We handle hosting for $20/month. That covers your server, SSL certificate, and uptime monitoring — no setup required on your end.'],
            ['How long does it take?', 'Most sites launch in 2–3 weeks, depending on how quickly content is available.'],
            ['Do you do ongoing updates?', 'Future support is available at a rate of $60/hour with a half-hour minimum.'],
          ].map(([q, a]) => (
            <div style="background: white; border-radius: 14px; padding: 22px 24px; border: 1px solid #e4eaf5;">
              <div style="font-size: 15px; font-weight: 700; color: #0F1F3D; margin-bottom: 8px;">{q}</div>
              <div style="font-size: 14px; color: #595959; line-height: 1.6;">{a}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── OUR WORK ── -->
  <section style="padding: 96px 0 72px; background: #0F1F3D; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0; opacity: 0.5;"></div>
    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="text-align: center; margin-bottom: 56px;">
        <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Our Work</span>
        <h2 style="font-size: clamp(32px, 5vw, 56px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 14px;">
          Sites built by <span class="grad-text">Sequel Web Studio.</span>
        </h2>
        <p style="font-size: 17px; color: rgba(255,255,255,0.55); max-width: 480px; margin: 0 auto;">
          Every site is custom-coded from scratch, no templates, no page builders.
        </p>
      </div>

      <div class="svc-portfolio-grid">
        {PORTFOLIO.map((site, i) => (
          <a
            href={site.href}
            target={site.external ? '_blank' : undefined}
            rel={site.external ? 'noopener noreferrer' : undefined}
            class={`reveal reveal-delay-${(i % 3) + 1} hover-card svc-portfolio-card`}
          >
            <div class="svc-portfolio-screenshot">
              <img src={site.img} alt={`${site.name} ${site.tag.toLowerCase()} website built by Sequel Web Studio`} class="svc-portfolio-img" loading="lazy" />
            </div>
            <div style="padding: 18px 20px; background: white;">
              <div style="font-size: 11px; font-weight: 600; color: #2E75B6; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">{site.tag}</div>
              <div style="font-size: 16px; font-weight: 700; color: #0F1F3D; margin-bottom: 4px;">{site.name}</div>
              <div style="font-size: 13px; color: #595959; line-height: 1.6;">{site.description}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WORK CTA ── -->
  <section style="background: linear-gradient(135deg, #1F3864 0%, #2E75B6 60%, #8E44AD 100%); padding: 80px 32px; text-align: center;">
    <h2 style="font-size: 32px; font-weight: 700; color: white; letter-spacing: -0.5px; margin-bottom: 16px;">Want a site like these?</h2>
    <p style="font-size: 16px; color: rgba(255,255,255,0.55); max-width: 440px; margin: 0 auto 32px;">
      Tell us about your business and we'll show you what's possible.
    </p>
    <a href="/contact" style="background: white; color: #0F1F3D; padding: 13px 32px; border-radius: 10px; font-size: 15px; font-weight: 700; text-decoration: none; display: inline-block; box-shadow: 0 8px 24px rgba(0,0,0,0.2);">
      Get in touch →
    </a>
  </section>

</BaseLayout>

<script>import '../scripts/accordion';</script>

<style>
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  @media (max-width: 640px) {
    .faq-grid { grid-template-columns: 1fr; }
  }

  .svc-portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }
  .svc-portfolio-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(15,31,61,0.08);
    border: 1px solid #e4eaf5;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .svc-portfolio-screenshot {
    height: 220px;
    overflow: hidden;
    background: #0F1F3D;
  }
  .svc-portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s ease;
  }
  .svc-portfolio-card:hover .svc-portfolio-img {
    transform: scale(1.04) translateY(-2%);
  }

  /* Dark-background accordion overrides for the Technical Foundation section */
  :global(.layers-dark .acc-item) {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
  }
  :global(.layers-dark .acc-item:hover) {
    background: rgba(255,255,255,0.08);
