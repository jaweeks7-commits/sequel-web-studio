---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Web Design Services — Sequel Web Studio"
  description="Flat-rate web design packages for small businesses in Northern Tarrant County, TX. Starter at $1,000. Premium at $2,000. No surprises."
>

  <!-- ── HERO ── -->
  <section style="background: #0F1F3D; padding: 140px 32px 80px; text-align: center; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1; max-width: 680px; margin: 0 auto;">
      <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Services &amp; Pricing</span>
      <h1 style="font-size: clamp(36px, 5vw, 64px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 16px;">
        Clean, fast websites.<br /><span class="grad-text">One-time price.</span>
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.55); max-width: 480px; margin: 0 auto;">
        No subscriptions. No retainers. Pay once and own your site outright.
      </p>
    </div>
    <svg viewBox="0 0 1440 60" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;" fill="none">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="#F4F6FB" />
    </svg>
  </section>

  <!-- ── PRICING + FAQ ── -->
  <section style="padding: 80px 32px 96px; background: #F4F6FB;">
    <div style="max-width: 900px; margin: 0 auto;">

      <!-- Pricing cards -->
      <div style="display: flex; gap: 28px; justify-content: center; flex-wrap: wrap; align-items: stretch; margin-bottom: 72px;">
        {[
          {
            name: 'Starter', price: '$1,000', tag: 'One-time fee',
            desc: 'Perfect for new businesses that need a professional web presence fast.',
            features: ['Up to 5 pages', 'Mobile-responsive design', 'Contact form with email delivery', 'Google Analytics setup', 'Schema.org local business markup', '30 days post-launch support'],
            cta: 'Get Started', featured: false,
          },
          {
            name: 'Premium', price: '$2,000', tag: 'One-time fee',
            desc: 'For businesses serious about ranking on Google and growing leads over time.',
            features: ['Everything in Starter', 'SEO optimization & keyword research', 'Blog or news section', 'Google Business Profile setup', 'Open Graph images for social', '60 days post-launch support'],
            cta: 'Start with Premium', featured: true,
          },
        ].map((plan, i) => (
          <div
            class={`reveal reveal-delay-${i + 1} hover-card`}
            style={`flex: 1 1 300px; max-width: 400px; background: ${plan.featured ? '#0F1F3D' : 'white'}; border-radius: 20px; padding: 40px 36px; box-shadow: ${plan.featured ? '0 20px 56px rgba(15,31,61,0.28)' : '0 8px 32px rgba(15,31,61,0.08)'}; border: ${plan.featured ? 'none' : '1px solid #e4eaf5'}; position: relative;`}
          >
            {plan.featured && (
              <div style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg,#2E75B6,#8E44AD); color: white; font-size: 11px; font-weight: 700; padding: 5px 18px; border-radius: 9999px; white-space: nowrap;">Most Popular</div>
            )}
            <div style={`font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: ${plan.featured ? '#4B9FD4' : '#2E75B6'}; margin-bottom: 12px;`}>{plan.name}</div>
            <div style={`font-size: 52px; font-weight: 700; color: ${plan.featured ? 'white' : '#0F1F3D'}; letter-spacing: -2px; line-height: 1;`}>{plan.price}</div>
            <div style={`font-size: 13px; color: ${plan.featured ? 'rgba(255,255,255,0.35)' : '#999'}; margin: 4px 0 16px;`}>{plan.tag}</div>
            <p style={`font-size: 14px; color: ${plan.featured ? 'rgba(255,255,255,0.55)' : '#595959'}; line-height: 1.6; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid ${plan.featured ? 'rgba(255,255,255,0.1)' : '#e4eaf5'};`}>{plan.desc}</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px;">
              {plan.features.map(f => (
                <li style={`display: flex; gap: 10px; font-size: 14px; color: ${plan.featured ? 'rgba(255,255,255,0.7)' : '#595959'}; line-height: 1.4; align-items: flex-start;`}>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink: 0; margin-top: 2px;">
                    <circle cx="8" cy="8" r="7" fill={plan.featured ? 'rgba(75,159,212,0.2)' : 'rgba(46,117,182,0.1)'} />
                    <path d="M5 8l2 2 4-4" stroke={plan.featured ? '#4B9FD4' : '#2E75B6'} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              style={`display: block; padding: 13px; border-radius: 10px; font-size: 14px; font-weight: 700; text-align: center; text-decoration: none; background: ${plan.featured ? 'linear-gradient(135deg,#2E75B6,#8E44AD)' : 'transparent'}; color: ${plan.featured ? 'white' : '#1F3864'}; border: ${plan.featured ? 'none' : '2px solid #1F3864'}; box-shadow: ${plan.featured ? '0 8px 24px rgba(46,117,182,0.35)' : 'none'};`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <div class="reveal">
        <h2 style="font-size: 28px; font-weight: 700; color: #0F1F3D; letter-spacing: -0.5px; margin-bottom: 8px; text-align: center;">Common Questions</h2>
        <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin: 0 auto 36px;"></div>
        <div class="faq-grid">
          {[
            ['Do I own my website?', 'Yes — completely. When the project is done, the site and all its files are yours. No platform lock-in.'],
            ['What about hosting?', "We recommend Netlify (free tier covers most small business sites). We'll help you get set up."],
            ['How long does it take?', 'Starter sites typically launch in 2–3 weeks. Premium in 3–5 weeks, depending on content availability.'],
            ['Do you do ongoing updates?', "Support windows are included (30 or 60 days). After that, we offer update packages — or teach you to make small edits yourself."],
          ].map(([q, a]) => (
            <div style="background: white; border-radius: 14px; padding: 22px 24px; border: 1px solid #e4eaf5;">
              <div style="font-size: 15px; font-weight: 700; color: #0F1F3D; margin-bottom: 8px;">{q}</div>
              <div style="font-size: 14px; color: #595959; line-height: 1.6;">{a}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  @media (max-width: 640px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
