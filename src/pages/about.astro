---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_URL, CONTACT_EMAIL, SOCIAL_LINKS } from '../config/site';

const personSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type':    'Person',
    '@id':      'https://sequelwebstudio.com/#founder',
    name:       'Joe Weeks',
    jobTitle:   'Co-Founder',
    url:        `${SITE_URL}/about`,
    email:      CONTACT_EMAIL,
    sameAs:     [SOCIAL_LINKS.linkedin, SOCIAL_LINKS.clutch],
    worksFor: {
      '@type': 'ProfessionalService',
      '@id':   'https://sequelwebstudio.com/#organization',
      name:    SITE_NAME,
      url:     SITE_URL,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type':    'Person',
    '@id':      'https://sequelwebstudio.com/#cofounder',
    name:       'Christina Weeks',
    jobTitle:   'Co-Founder',
    url:        `${SITE_URL}/about`,
    worksFor: {
      '@type': 'ProfessionalService',
      '@id':   'https://sequelwebstudio.com/#organization',
      name:    SITE_NAME,
      url:     SITE_URL,
    },
  },
]);
---

<BaseLayout
  title="About Joe & Christina Weeks | Sequel Web Studio"
  description="Sequel Web Studio is a husband-and-wife web studio founded by Joe and Christina Weeks in North Fort Worth, TX. We build AI-ready websites for small businesses across the US."
  ogImage="https://sequelwebstudio.com/images/og-home.png"
>
  <script type="application/ld+json" set:html={personSchema} slot="head" />

  <!-- ── HERO ── -->
  <section style="background: #0F1F3D; padding: 140px 32px 152px; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1; max-width: 1160px; margin: 0 auto;">
      <div class="hero-grid">
        <!-- Copy -->
        <div>
          <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">About Us</span>
          <h1 style="font-size: clamp(36px, 5vw, 60px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 20px;">
            Built different.<br /><span class="grad-text">By design.</span>
          </h1>
          <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin-bottom: 24px;"></div>
          <p style="font-size: 17px; color: rgba(255,255,255,0.65); line-height: 1.75; margin-bottom: 14px;">
            Sequel Web Studio is a husband-and-wife studio — Joe and Christina Weeks — based in North Fort Worth, TX. When you hire us, you work directly with our team, not an account manager, not an outsourced developer. We handle every conversation ourselves.
          </p>
          <p style="font-size: 17px; color: rgba(255,255,255,0.65); line-height: 1.75; margin-bottom: 36px;">
            We serve small business owners across the US who need a real web presence, not a template from a page builder.
          </p>
          <a href="/contact" style="background: linear-gradient(135deg,#2E75B6,#8E44AD); color: white; padding: 13px 28px; border-radius: 10px; font-size: 14px; font-weight: 700; text-decoration: none; display: inline-block; box-shadow: 0 8px 24px rgba(46,117,182,0.4);">
            Work with us →
          </a>
          <div style="display: flex; flex-wrap: wrap; gap: 20px; margin-top: 18px;">
            <a
              href={SOCIAL_LINKS.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 7px; color: rgba(255,255,255,0.6); font-size: 14px; text-decoration: none; transition: color 0.2s;"
              class="li-link"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 16px; height: 16px; flex-shrink: 0;" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Connect on LinkedIn
            </a>
            <a
              href={SOCIAL_LINKS.clutch}
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 7px; color: rgba(255,255,255,0.6); font-size: 14px; text-decoration: none; transition: color 0.2s;"
              class="li-link"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 16px; height: 16px; flex-shrink: 0;" aria-hidden="true">
                <path d="M19.07 4.93A10 10 0 1 0 19.07 19.07L16.6 16.6A6.5 6.5 0 1 1 16.6 7.4Z"/>
              </svg>
              View on Clutch
            </a>
          </div>
        </div>

        <!-- Photo -->
        <div style="position: relative;">
          <div style="position: absolute; inset: -20px; background: linear-gradient(135deg, rgba(46,117,182,0.15), rgba(142,68,173,0.15)); border-radius: 32px; transform: rotate(-2deg);"></div>
          <img
            src="/images/joe-christina-founders.webp"
            alt="Joe and Christina Weeks, co-founders of Sequel Web Studio"
            width="824"
            height="833"
            style="position: relative; width: 100%; height: auto; border-radius: 24px; display: block; box-shadow: 0 32px 80px rgba(0,0,0,0.4);"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
    <svg viewBox="0 0 1440 60" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;" fill="none">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── VALUES ── -->
  <section style="padding: 48px 32px 80px; background: white;">
    <div style="max-width: 1000px; margin: 0 auto;">
      <div class="reveal" style="text-align: center; margin-bottom: 48px;">
        <h2 style="font-size: 32px; font-weight: 700; color: #0F1F3D; letter-spacing: -0.5px;">The Sequel way.</h2>
        <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin: 12px auto 0;"></div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
        {[
          ['Transparency first', "You'll always know what you're getting, how much it costs, and when it'll be done."],
          ['Performance-centric', "Performance isn't an afterthought. Every site targets 95+ on Lighthouse before it ships."],
          ['Always direct', "You work with our team directly, not an account manager, outsourced developer, or offshore firm. Call, text, or email."],
          ['No surprises', "One flat price covers design, build, and launch. Hosting is $20/month. If anything extra is needed, we quote it up front in plain English."],
        ].map(([title, desc], i) => (
          <div class={`reveal reveal-delay-${i + 1} hover-card`} style="background: #F4F6FB; border-radius: 14px; padding: 24px; border: 1px solid #e4eaf5; box-shadow: 0 4px 16px rgba(15,31,61,0.06);">
            <div style="height: 3px; width: 32px; background: #8E44AD; border-radius: 9999px; margin-bottom: 14px;"></div>
            <div style="font-size: 17px; font-weight: 700; color: #0F1F3D; margin-bottom: 8px;">{title}</div>
            <div style="font-size: 14px; color: #595959; line-height: 1.65;">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .li-link:hover {
    color: rgba(255,255,255,0.85) !important;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 72px;
    align-items: center;
  }
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-grid > div:nth-child(2) {
      order: -1;
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>
