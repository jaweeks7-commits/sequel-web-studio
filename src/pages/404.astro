---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="Sorry, we can't find that page — it may have moved or never existed. Return to Sequel Web Studio for custom-coded websites built for small businesses across the US.">
  <section class="py-32 bg-brand-bg text-center">
    <div class="max-w-xl mx-auto px-4 sm:px-6">
      <p class="text-8xl font-bold text-brand-navy opacity-20 leading-none">404</p>
      <h1 class="mt-4 text-3xl font-bold text-brand-navy">Page Not Found</h1>
      <p class="mt-4 text-brand-grey">
        Sorry, we can't find that page. It may have moved or never existed.
      </p>
      <a href="/" class="mt-8 inline-block btn-primary">Back to Home</a>
    </div>
  </section>
</BaseLayout>
