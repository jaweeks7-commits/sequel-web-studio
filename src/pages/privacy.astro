---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME, CONTACT_EMAIL, SERVICE_AREA } from '../config/site';
---

<BaseLayout title="Privacy Policy" description="Read Sequel Web Studio's privacy policy to understand how we collect, use, and protect your data when you visit sequelwebstudio.com.">
  <section class="py-16 bg-brand-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl font-bold text-brand-navy mb-2">Privacy Policy</h1>
      <p class="text-sm text-brand-grey mb-10">Last updated: April 2026</p>

      <div class="space-y-6 text-brand-grey leading-relaxed">
        <p>
          {SITE_NAME} ("we", "us", or "our") operates the website sequelwebstudio.com. This page informs you of our policies regarding the collection, use, and disclosure of personal data when you use our site.
        </p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Information We Collect</h2>
        <p>We collect information you provide directly, such as your name and email address when you fill out our contact form. We also collect standard analytics data (pages visited, approximate location, device type) through Google Analytics when you consent to cookies.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">How We Use Your Information</h2>
        <p>We use the information you submit to respond to your inquiry. We use analytics data to understand how visitors use the site so we can improve it.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Cookies</h2>
        <p>We use cookies only with your consent. You can manage your preferences at any time using the cookie banner. Declining analytics cookies will prevent Google Analytics from tracking your visit.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Third-Party Services</h2>
        <p>We use Google Analytics (Google LLC) for usage analytics. Please review Google's privacy policy for information on how Google handles data.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Contact</h2>
        <p>
          Questions about this policy? Email us at{' '}
          <a href={`mailto:${CONTACT_EMAIL}`} class="text-brand-blue hover:underline">{CONTACT_EMAIL}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
