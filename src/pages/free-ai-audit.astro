---
// Dedicated Google Ads landing page (noindex, minimal chrome).
// Job: get a paid-search visitor to run the free scan above the fold,
// then let the AuditForm's built-in upsell carry them to the $350 package.
// Message-matched to the search intent "website audit / AI search".
import BaseLayout from '../layouts/BaseLayout.astro';
import AuditForm from '../components/AuditForm.astro';
---

<BaseLayout
  title="Free AI Visibility Scan — See Your Score in 60 Seconds"
  description="Is your website invisible to ChatGPT, Perplexity, and Google AI? Run a free scan and see your real scores in seconds. No email required."
  minimal
  noindex
>
  <!-- ── HERO: the scan IS the page ── -->
  <section style="position: relative; background: #0F1F3D; min-height: 100vh; display: flex; align-items: center; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div class="blob-1" style="position: absolute; top: 5%; left: -8%; width: 560px; height: 560px; border-radius: 50%; background: radial-gradient(circle, rgba(46,117,182,0.25) 0%, transparent 70%); pointer-events: none;"></div>
    <div class="blob-2" style="position: absolute; bottom: 10%; right: -4%; width: 440px; height: 440px; border-radius: 50%; background: radial-gradient(circle, rgba(142,68,173,0.2) 0%, transparent 70%); pointer-events: none;"></div>

    <div class="hero-inner" style="position: relative; z-index: 1; max-width: 820px; margin: 0 auto; padding: 110px 32px 80px; width: 100%; text-align: center;">

      <!-- Eyebrow -->
      <div class="hero-eyebrow" style="display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.13); border-radius: 9999px; padding: 6px 14px; margin-bottom: 26px;">
        <div style="width: 7px; height: 7px; border-radius: 50%; background: #2E75B6; flex-shrink: 0; animation: pulse-dot 2s ease-in-out infinite;"></div>
        <span style="font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.65);">Free AI Visibility Scan · No Email Required</span>
      </div>

      <h1 class="hero-title" style="font-size: clamp(30px, 4.4vw, 54px); font-weight: 700; color: white; line-height: 1.12; letter-spacing: -1.4px; margin-bottom: 18px;">
        Is your website invisible to
        <span style="background: linear-gradient(135deg, #2E75B6, #8E44AD); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">ChatGPT?</span><br />
        Find out free — in 60 seconds.
      </h1>

      <p class="hero-intro hero-intro-full" style="font-size: 17px; color: rgba(255,255,255,0.7); line-height: 1.7; max-width: 560px; margin: 0 auto 34px;">
        ChatGPT, Perplexity, Siri, and Google AI are answering your customers' questions right now. Paste your URL below and see whether they can find your business — real scores, in seconds.
      </p>
      <!-- Shorter intro shown only on phones, so the scan box clears the fold -->
      <p class="hero-intro hero-intro-short" style="font-size: 15px; color: rgba(255,255,255,0.7); line-height: 1.6; max-width: 560px; margin: 0 auto 20px;">
        Can ChatGPT and Google AI find your business? Paste your URL and get real scores in seconds.
      </p>

      <!-- The scan — front and center -->
      <div style="text-align: left; max-width: 560px; margin: 0 auto;">
        <AuditForm dark />
      </div>

      <!-- Proof strip -->
      <div class="proof-strip" style="margin-top: 44px; display: flex; gap: 12px 36px; flex-wrap: wrap; justify-content: center; align-items: center;">
        {[['5 categories', 'scored instantly'], ['Live signals', 'from your real site'], ['100% free', 'no credit card']].map(([val, label]) => (
          <div style="text-align: center;">
            <div style="font-size: 18px; font-weight: 700; color: white; letter-spacing: -0.4px; line-height: 1;">{val}</div>
            <div style="font-size: 11px; color: rgba(255,255,255,0.6); margin-top: 4px;">{label}</div>
          </div>
        ))}
      </div>

      <p style="margin-top: 30px; font-size: 12px; color: rgba(255,255,255,0.55);">
        As featured in
        <a href="https://communityimpact.com/dallas-fort-worth/keller-roanoke-northeast-fort-worth/business/2026/05/19/north-fort-worth-based-sequel-web-studio-launches-ai-focused-web-services/" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.8); font-weight: 600;">Community Impact Newspaper</a>
      </p>
    </div>

    <svg viewBox="0 0 1440 60" fill="none" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="white" />
    </svg>
  </section>

  <!-- ── WHAT THE SCAN CHECKS ── -->
  <section style="padding: 80px 0 64px; background: white;">
    <div style="max-width: 920px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="text-align: center; margin-bottom: 44px;">
        <span style="font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6;">The Free Scan</span>
        <h2 style="font-size: clamp(26px, 3.4vw, 40px); font-weight: 700; color: #0F1F3D; letter-spacing: -1px; line-height: 1.15; margin-top: 10px;">
          Five scores. Real signals. Honest answers.
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
        {[
          ['Performance', 'How fast your page actually loads for a real visitor — the #1 reason people leave.'],
          ['SEO / Discoverability', 'Whether Google can read, index, and correctly describe your business.'],
          ['AI Readiness', 'Whether ChatGPT, Perplexity, and voice assistants can find and quote you.'],
          ['Mobile Experience', 'How your site behaves on the phones most of your customers are using.'],
          ['Security & Compliance', 'The padlock, the policies, and the settings that make visitors (and Google) trust you.'],
        ].map(([title, body]) => (
          <div class="reveal" style="background: #F7F8FA; border: 1px solid #e4eaf5; border-radius: 14px; padding: 22px 24px;">
            <div style="font-size: 15px; font-weight: 700; color: #0F1F3D; margin-bottom: 8px;">{title}</div>
            <p style="font-size: 13px; color: #595959; line-height: 1.6; margin: 0;">{body}</p>
          </div>
        ))}
        <div class="reveal" style="background: #0F1F3D; border-radius: 14px; padding: 22px 24px; display: flex; flex-direction: column; justify-content: center;">
          <div style="font-size: 15px; font-weight: 700; color: white; margin-bottom: 8px;">Takes 60 seconds.</div>
          <p style="font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.6; margin: 0 0 14px;">No email. No credit card. No sales call unless you ask.</p>
          <a href="#top-scan" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;" style="font-size: 13px; font-weight: 700; color: #4B9FD4; text-decoration: underline;">Run your free scan ↑</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── UPSELL: PRO DIAGNOSIS ── -->
  <section style="padding: 72px 0 96px; background: white;">
    <div style="max-width: 920px; margin: 0 auto; padding: 0 32px;">
      <div class="reveal" style="background: #F7F8FA; border: 1px solid #e4eaf5; border-top: 4px solid #0F1F3D; border-radius: 18px; padding: 44px 40px;">
        <span style="font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #2E75B6;">When You're Ready for the Fixes</span>
        <h2 style="font-size: clamp(24px, 3.2vw, 36px); font-weight: 700; color: #0F1F3D; letter-spacing: -0.8px; line-height: 1.18; margin: 12px 0 16px;">
          The free scan shows what's wrong.<br />The Pro Diagnosis hands you the fix for every issue.
        </h2>
        <p style="font-size: 15px; color: #595959; line-height: 1.7; max-width: 640px; margin-bottom: 26px;">
          A 28-point deep diagnosis of your site by a real AI agent in a live browser — every issue explained in plain English, with ready-to-paste code fixes written for your platform. Delivered as a branded report within 24 hours.
        </p>

        <ul style="list-style: none; padding: 0; margin: 0 0 30px; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px 24px;">
          {[
            'Ready-to-paste code for every fixable problem',
            '28-point scan across 8 categories',
            'Platform-specific steps — WordPress, Wix, Squarespace & more',
            'Priority-ranked action list: fix this first',
            'Plain-English explanation for every finding',
            'Delivered within 24 hours',
          ].map(item => (
            <li style="display: flex; align-items: flex-start; gap: 9px; font-size: 14px; color: #595959; line-height: 1.5;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;">
                <circle cx="8" cy="8" r="7" fill="rgba(46,117,182,0.1)" />
                <path d="M5 8l2 2 4-4" stroke="#2E75B6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <a href="/audit#order" style="display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 15px 30px; border-radius: 10px; font-size: 16px; font-weight: 700; text-decoration: none; box-shadow: 0 8px 28px rgba(46,117,182,0.4); letter-spacing: -0.2px;">
          Get Your Pro Diagnosis + Remedy Package — $350 →
        </a>
        <p style="margin-top: 14px; font-size: 13px; color: #6B7280; line-height: 1.6;">
          One-time payment · No subscription · <strong style="color: #0F1F3D;">Money-back guarantee</strong> if we can't find anything to improve
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Animated hero blobs — same motion as the homepage hero */
  @keyframes float-1 { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(20px, -15px); } }
  @keyframes float-2 { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-15px, 20px); } }
  .blob-1 { animation: float-1 10s ease-in-out infinite; }
  .blob-2 { animation: float-2 13s ease-in-out infinite; }

  /* Eyebrow dot pulse */
  @keyframes pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.4); } }

  /* Mobile fold fix: paid clicks land here on phones, and the cookie banner
     covers the bottom ~230px, so the hero must be short enough that the scan
     box is visible on arrival. The page is styled inline (desktop baseline),
     hence the !important overrides. */
  .hero-intro-short { display: none; }
  @media (max-width: 640px) {
    .hero-inner { padding: 88px 24px 64px !important; }
    .hero-eyebrow { margin-bottom: 14px !important; }
    .hero-title { font-size: 28px !important; letter-spacing: -0.8px !important; margin-bottom: 12px !important; }
    .hero-intro-full { display: none !important; }
    .hero-intro-short { display: block !important; }
    .proof-strip { margin-top: 26px !important; }
  }
</style>
