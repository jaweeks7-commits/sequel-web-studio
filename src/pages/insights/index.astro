---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_URL } from '../../config/site';

const allArticles = await getCollection('insights');
const sorted = allArticles.sort((a, b) => a.data.publishOrder - b.data.publishOrder);
const featuredArticle = sorted.find(a => a.data.featured) ?? null;

const categoryMeta: Record<string, { label: string; description: string }> = {
  methodology:  { label: 'Methodology',     description: 'How a professional audit works, what we check, and why we do it the way we do.' },
  pricing:      { label: 'Pricing & ROI',   description: 'What a website audit costs, why, and how to measure the return.' },
  findings:     { label: 'Common Findings', description: 'What we consistently find on small business sites, with specifics.' },
  myths:        { label: 'Myths & Misconceptions', description: 'What automated tools and platform dashboards get wrong, and why it matters.' },
  deliverable:  { label: 'What You Receive', description: 'The exact format, sections, and contents of the delivered PDF.' },
};

const categoryOrder: Array<keyof typeof categoryMeta> = [
  'methodology', 'pricing', 'findings', 'myths', 'deliverable',
];

const byCategory = categoryOrder.map(cat => ({
  ...categoryMeta[cat],
  key: cat,
  articles: sorted.filter(a => a.data.category === cat && !a.data.featured),
}));

const lengthLabel: Record<string, string> = {
  short:  '~5 min',
  medium: '~8 min',
  long:   '~12 min',
};

const categoryBadgeStyle: Record<string, string> = {
  methodology:  'background: #e8f0fb; color: #1F3864;',
  pricing:      'background: #e8f5ec; color: #1a6633;',
  findings:     'background: #f3eafb; color: #5e2a8a;',
  myths:        'background: #fef3e2; color: #8a5200;',
  deliverable:  'background: #e8f0fb; color: #1F3864;',
};

const insightsBreadcrumb = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',     item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Insights', item: `${SITE_URL}/insights` },
  ],
});

const itemListSchema = JSON.stringify({
  '@context':     'https://schema.org',
  '@type':        'ItemList',
  name:           'Website Audit Insights',
  description:    'Articles on professional website audits — methodology, findings, pricing, and what you receive.',
  url:            `${SITE_URL}/insights`,
  numberOfItems:  sorted.length,
  itemListElement: sorted.map((a, i) => ({
    '@type':      'ListItem',
    position:     i + 1,
    name:         a.data.title,
    url:          `${SITE_URL}/insights/${a.id}`,
    description:  a.data.description,
  })),
});
---

<BaseLayout
  title="Insights — Website Audit Education | Sequel Web Studio"
  description="23 articles on what a professional website audit is, what we find on small business sites, why automated scanners miss what matters, and how a $350 audit pays for itself."
  ogImage={`${SITE_URL}/images/og-insights.png`}
>
  <script type="application/ld+json" set:html={insightsBreadcrumb} slot="head" />
  <script type="application/ld+json" set:html={itemListSchema}     slot="head" />

  <!-- ── HERO ── -->
  <section style="background: #0F1F3D; padding: 140px 32px 100px; position: relative; overflow: hidden;">
    <div class="dot-grid" style="position: absolute; inset: 0;"></div>
    <div style="position: relative; z-index: 1; max-width: 860px; margin: 0 auto; text-align: center;">
      <span style="font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #4B9FD4;">Insights</span>
      <h1 style="font-size: clamp(32px, 5vw, 56px); font-weight: 700; color: white; letter-spacing: -1.5px; line-height: 1.1; margin-top: 14px; margin-bottom: 20px;">
        What a real website audit looks like.
      </h1>
      <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin: 0 auto 24px;"></div>
      <p style="font-size: 17px; color: rgba(255,255,255,0.65); line-height: 1.75; max-width: 640px; margin: 0 auto 32px;">
        23 articles on what a professional website audit is, what we consistently find on small business sites, why free scanners miss the issues that matter, and what you actually receive when you order one.
      </p>
      <a
        href="/audit#order"
        style="background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 13px 28px; border-radius: 10px; font-size: 14px; font-weight: 700; text-decoration: none; display: inline-block; box-shadow: 0 8px 24px rgba(46,117,182,0.4);"
      >
        Get Your Audit — $350
      </a>
    </div>
    <svg viewBox="0 0 1440 60" style="position: absolute; bottom: -1px; left: 0; right: 0; display: block; width: 100%;" fill="none">
      <path d="M0 60 L0 30 Q720 -10 1440 30 L1440 60 Z" fill="#F7F8FA" />
    </svg>
  </section>

  <!-- ── FEATURED RESEARCH SPOTLIGHT ── -->
  {featuredArticle && (
    <section style="background: #F7F8FA; padding: 40px 32px 0;">
      <div style="max-width: 1160px; margin: 0 auto;">
        <a
          href={`/insights/${featuredArticle.id}`}
          class="featured-spotlight"
          style="display: block; background: white; border-radius: 16px; border: 1px solid #e4eaf5; border-left: 4px solid #8E44AD; box-shadow: 0 4px 24px rgba(15,31,61,0.07); padding: 36px 40px; text-decoration: none;"
        >
          <div style="display: flex; align-items: flex-start; gap: 40px; flex-wrap: wrap;">
            <div style="display: flex; flex-direction: column; gap: 12px; min-width: 200px; flex-shrink: 0;">
              <span style="font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #8E44AD; margin-bottom: 4px;">New Research</span>
              {[
                { value: '24', label: 'sites audited' },
                { value: '96%', label: 'had critical findings' },
                { value: '4.8', label: 'avg critical per site' },
              ].map(stat => (
                <div style="background: #f3eafb; border-radius: 10px; padding: 10px 16px; text-align: center;">
                  <div style="font-size: 22px; font-weight: 700; color: #5e2a8a; letter-spacing: -0.5px;">{stat.value}</div>
                  <div style="font-size: 11px; color: #7a4a9a; margin-top: 2px;">{stat.label}</div>
                </div>
              ))}
            </div>
            <div style="flex: 1; min-width: 240px;">
              <h2 style="font-size: clamp(18px, 2.5vw, 26px); font-weight: 700; color: #0F1F3D; letter-spacing: -0.4px; line-height: 1.3; margin-bottom: 12px;">
                {featuredArticle.data.title}
              </h2>
              <p style="font-size: 15px; color: #595959; line-height: 1.7; margin-bottom: 20px; max-width: 600px;">
                {featuredArticle.data.description}
              </p>
              <span style="font-size: 14px; font-weight: 600; color: #8E44AD;">Read the research →</span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ── ARTICLES BY CATEGORY ── -->
  <section style="background: #F7F8FA; padding: 72px 32px 96px;">
    <div style="max-width: 1160px; margin: 0 auto;">

      {byCategory.map(({ key, label, description, articles }) => articles.length > 0 && (
        <div class="reveal" style="margin-bottom: 72px;">
          <!-- Category header -->
          <div style="display: flex; align-items: flex-start; gap: 24px; margin-bottom: 32px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
              <h2 style="font-size: 22px; font-weight: 700; color: #0F1F3D; letter-spacing: -0.3px; margin-bottom: 6px;">{label}</h2>
              <p style="font-size: 14px; color: #595959; line-height: 1.6; max-width: 560px;">{description}</p>
            </div>
            <div style="height: 3px; width: 48px; background: #8E44AD; border-radius: 9999px; margin-top: 8px; flex-shrink: 0;"></div>
          </div>

          <!-- Cards grid -->
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
            {articles.map(article => (
              <a
                href={`/insights/${article.id}`}
                style="background: white; border-radius: 14px; padding: 28px; border: 1px solid #e4eaf5; box-shadow: 0 4px 16px rgba(15,31,61,0.05); text-decoration: none; display: flex; flex-direction: column; transition: box-shadow 0.2s, transform 0.2s;"
                class="insight-card"
              >
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; gap: 8px; flex-wrap: wrap;">
                  <span style={`font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 3px 9px; border-radius: 5px; ${categoryBadgeStyle[key]}`}>
                    {label}
                  </span>
                  <span style="font-size: 12px; color: #6B7280;">
                    {lengthLabel[article.data.length]}
                  </span>
                </div>
                <h3 style="font-size: 16px; font-weight: 700; color: #0F1F3D; line-height: 1.4; margin-bottom: 10px; letter-spacing: -0.2px;">
                  {article.data.title}
                </h3>
                <p style="font-size: 14px; color: #595959; line-height: 1.6; flex: 1; margin-bottom: 18px;">
                  {article.data.description}
                </p>
                <span style="font-size: 13px; font-weight: 600; color: #2E75B6;">Read more →</span>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section style="background: #0F1F3D; padding: 72px 32px;">
    <div style="max-width: 640px; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 28px; font-weight: 700; color: white; letter-spacing: -0.5px; margin-bottom: 14px;">
        Ready to see what's actually on your site?
      </h2>
      <p style="font-size: 16px; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 28px;">
        The Pro Diagnosis + Remedy Package is a 28-point human-reviewed audit of your website, delivered as a single PDF within 24 hours. Every Critical and High Value finding comes with step-by-step instructions to fix it.
      </p>
      <a
        href="/audit#order"
        style="background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 14px 32px; border-radius: 10px; font-size: 15px; font-weight: 700; text-decoration: none; display: inline-block; box-shadow: 0 8px 24px rgba(46,117,182,0.35);"
      >
        Order Your Diagnosis — $350
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .insight-card:hover {
    box-shadow: 0 8px 32px rgba(15,31,61,0.12) !important;
    transform: translateY(-2px);
  }
  .featured-spotlight:hover {
    box-shadow: 0 8px 36px rgba(15,31,61,0.13) !important;
    transform: translateY(-2px);
    transition: box-shadow 0.2s, transform 0.2s;
  }
</style>
