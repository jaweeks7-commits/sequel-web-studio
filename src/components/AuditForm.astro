---
// Reusable Free Lite Audit form. Posts the URL to /.netlify/functions/audit,
// which runs a real scan (live HTML + header signals, plus PageSpeed for the
// performance score) and returns site-specific category scores rendered below.

interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

// Turnstile renders only when the site key is configured, mirroring the
// server's "no secret = skip" gating (see netlify/lib/turnstile.ts) so the
// form never breaks while bot protection is off.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<div class={`audit-widget${dark ? ' audit-dark' : ''}`} data-audit-widget>

  <!-- Idle / Running state -->
  <form data-audit-form novalidate>
    <div class="audit-row">
      <label for="audit-url" class="sr-only">Your website URL</label>
      <input
        type="text"
        id="audit-url"
        name="url"
        placeholder="yoursite.com"
        autocomplete="off"
        data-audit-input
        class="audit-input"
      />
      <button type="submit" data-audit-btn class="audit-btn">
        <span data-btn-label>Run Free Audit</span>
        <span data-btn-spinner hidden aria-hidden="true">
          <svg class="spin" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
            <path d="M8 2a6 6 0 0 1 6 6" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Scanning…
        </span>
      </button>
    </div>

    <!-- Honeypot — a real visitor never fills this; a bot usually does. -->
    <p class="audit-hp" aria-hidden="true">
      <label>Leave this field empty
        <input type="text" tabindex="-1" autocomplete="off" name="bot-field" data-audit-hp />
      </label>
    </p>

    {turnstileSiteKey && (
      <div
        class="cf-turnstile"
        data-sitekey={turnstileSiteKey}
        data-theme="auto"
        style="margin-top: 12px;"
      ></div>
    )}

    <p class="audit-trust">No email required to see your score. No credit card. No sales call unless you ask.</p>
    <p data-audit-error role="alert" hidden class="audit-error"></p>
  </form>

  <!-- Done state — results card, populated from the live scan response -->
  <div data-audit-result hidden class="audit-result">
    <div class="result-header">
      <span data-result-url class="result-url"></span>
      <span class="result-badge">Report Ready</span>
    </div>
    {[
      ['performance', 'Performance'],
      ['seo',         'SEO / Discoverability'],
      ['ai',          'AI Readiness'],
      ['mobile',      'Mobile Experience'],
      ['security',    'Security & Compliance'],
    ].map(([key, label]) => (
      <div class="score-row" data-score-row={key}>
        <div class="score-labels">
          <span class="score-label">{label}</span>
          <span class="score-value" data-score-value>—</span>
        </div>
        <div class="score-track">
          <div class="score-fill" data-score-fill style="width: 0%;"></div>
        </div>
      </div>
    ))}
    <div class="result-footer" data-result-footer></div>
  </div>

  <!-- Post-audit upsell card -->
  <div data-audit-upsell hidden class="audit-upsell">
    <p class="upsell-eyebrow">YOUR SITE HAS FIXABLE ISSUES</p>
    <p class="upsell-headline">These scores show what's wrong. The Pro Diagnosis + Remedy Package shows you exactly how to fix every issue — with ready-to-paste code.</p>
    <ul class="upsell-list">
      {[
        'Ready-to-paste code fixes for every problem we find',
        '28-point deep scan across all eight layers, explained in plain English',
        'Priority-ranked action list: critical, high-value, and nice-to-have',
        'Delivered within 24 hours',
      ].map(item => (
        <li class="upsell-list-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="upsell-check">
            <circle cx="8" cy="8" r="7" fill="rgba(46,117,182,0.1)" />
            <path d="M5 8l2 2 4-4" stroke="#2E75B6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {item}
        </li>
      ))}
    </ul>
    <a href="/audit#order" class="upsell-btn">Get Your Pro Diagnosis + Remedy Package — $350 →</a>
    <p class="upsell-reassurance">One-time payment · No subscription · Delivered within 24 hours</p>
  </div>
</div>

<style>
  .audit-widget { max-width: 560px; }

  .audit-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .audit-input {
    flex: 1 1 200px;
    padding: 13px 18px;
    border-radius: 10px;
    border: 1.5px solid #d0d9e8;
    background: white;
    color: #0F1F3D;
    font-size: 15px;
    font-family: inherit;
    min-width: 0;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .audit-input::placeholder { color: #6B7280; }
  .audit-input:focus {
    border-color: #2E75B6;
    box-shadow: 0 0 0 3px rgba(46,117,182,0.12);
  }

  .audit-dark .audit-input {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.06);
    color: white;
  }
  .audit-dark .audit-input::placeholder { color: rgba(255,255,255,0.6); }
  .audit-dark .audit-input:focus {
    border-color: rgba(255,255,255,0.6);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.06);
  }

  .audit-btn {
    padding: 13px 24px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    background: linear-gradient(135deg, #2E75B6, #8E44AD);
    color: white;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    box-shadow: 0 6px 20px rgba(46,117,182,0.35);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity 0.2s;
  }
  .audit-btn:disabled { opacity: 0.75; cursor: not-allowed; }

  /* Honeypot — kept in the layout but off-screen and out of the tab order. */
  .audit-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .audit-trust {
    margin-top: 10px;
    font-size: 12px;
    color: #6B7280;
    line-height: 1.5;
  }
  .audit-dark .audit-trust { color: rgba(255,255,255,0.6); }

  .audit-error {
    margin-top: 8px;
    font-size: 13px;
    color: #DC2626;
    line-height: 1.4;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 0.75s linear infinite; display: block; }

  /* Results card */
  .audit-result {
    background: #F4F6FB;
    border-radius: 14px;
    padding: 24px 28px;
    border: 1px solid #e4eaf5;
  }
  .audit-dark .audit-result {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .result-url {
    font-size: 12px;
    font-family: 'Space Mono', monospace;
    color: #2E75B6;
    word-break: break-all;
  }
  .audit-dark .result-url { color: #4B9FD4; }

  .result-badge {
    font-size: 11px;
    font-weight: 600;
    color: #16A34A;
    background: rgba(22,163,74,0.1);
    padding: 2px 10px;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .score-row { margin-bottom: 10px; }
  .score-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .score-label { font-size: 12px; color: #595959; }
  .audit-dark .score-label { color: rgba(255,255,255,0.65); }
  .score-value { font-size: 12px; font-weight: 700; }

  .score-track {
    height: 5px;
    background: #e4eaf5;
    border-radius: 9999px;
    overflow: hidden;
  }
  .audit-dark .score-track { background: rgba(255,255,255,0.08); }
  .score-fill { height: 5px; border-radius: 9999px; }

  .result-footer {
    margin-top: 14px;
    font-size: 13px;
    color: #6B7280;
  }
  .audit-dark .result-footer { color: rgba(255,255,255,0.6); }
  /* Upsell card */
  .audit-upsell {
    margin-top: 16px;
    background: #fff;
    border: 1px solid #e4eaf5;
    border-top: 3px solid #0F1F3D;
    border-radius: 14px;
    padding: 24px 28px;
  }

  .upsell-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #2E75B6;
    margin: 0 0 10px;
  }

  .upsell-headline {
    font-size: 15px;
    font-weight: 600;
    color: #0F1F3D;
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .upsell-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .upsell-list-item {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 13px;
    color: #595959;
    line-height: 1.45;
  }

  .upsell-check { flex-shrink: 0; margin-top: 1px; }

  .upsell-btn {
    display: block;
    width: 100%;
    padding: 13px 20px;
    border-radius: 10px;
    background: linear-gradient(135deg, #2E75B6, #8E44AD);
    color: white;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    text-align: center;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(46,117,182,0.35);
    transition: opacity 0.2s;
    box-sizing: border-box;
  }
  .upsell-btn:hover { opacity: 0.9; }

  .upsell-reassurance {
    margin: 10px 0 0;
    font-size: 12px;
    color: #6B7280;
    text-align: center;
    line-height: 1.5;
  }
</style>

<script>
  import { reportConversion } from '../lib/conversions';

  // <50 = red, 50–79 = amber, 80+ = green (matches the audit report tiers).
  function colorFor(score: number): string {
    if (score < 50) return '#DC2626';
    if (score < 80) return '#D97706';
    return '#16A34A';
  }

  const clampScore = (n: unknown): number =>
    Math.max(0, Math.min(100, Math.round(Number(n) || 0)));

  document.querySelectorAll<HTMLElement>('[data-audit-widget]').forEach(widget => {
    const form    = widget.querySelector<HTMLFormElement>('[data-audit-form]')!;
    const input   = widget.querySelector<HTMLInputElement>('[data-audit-input]')!;
    const btn     = widget.querySelector<HTMLButtonElement>('[data-audit-btn]')!;
    const label   = btn.querySelector<HTMLElement>('[data-btn-label]')!;
    const spinner = btn.querySelector<HTMLElement>('[data-btn-spinner]')!;
    const errEl   = widget.querySelector<HTMLElement>('[data-audit-error]')!;
    const result  = widget.querySelector<HTMLElement>('[data-audit-result]')!;
    const upsell  = widget.querySelector<HTMLElement>('[data-audit-upsell]')!;
    const urlEl   = result.querySelector<HTMLElement>('[data-result-url]')!;
    const footer  = result.querySelector<HTMLElement>('[data-result-footer]')!;
    const hp      = widget.querySelector<HTMLInputElement>('[data-audit-hp]');

    const setRunning = (on: boolean) => {
      btn.disabled = on;
      label.hidden = on;
      spinner.hidden = !on;
    };
    const showError = (msg: string) => {
      errEl.textContent = msg;
      errEl.hidden = false;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.hidden = true;
      errEl.textContent = '';

      let url = input.value.trim();
      if (!url) {
        showError('Please enter your website URL.');
        input.focus();
        return;
      }
      if (!/^https?:\/\//i.test(url)) url = 'https://' + url;
      try { new URL(url); } catch {
        showError("That doesn't look like a valid URL — try something like yoursite.com");
        input.focus();
        return;
      }

      const tokenInput = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
      const turnstileToken = tokenInput ? tokenInput.value : '';

      setRunning(true);
      try {
        const res = await fetch('/.netlify/functions/audit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          // page: which page hosted the widget — lets the lead log distinguish
          // ad-landing-page scans from homepage scans.
          body: JSON.stringify({ url, botField: hp?.value ?? '', turnstileToken, page: location.pathname }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          throw new Error(
            data.error || 'Something went wrong running your scan. Please try again.',
          );
        }

        const scores = (data.scores ?? {}) as Record<string, number>;
        widget.querySelectorAll<HTMLElement>('[data-score-row]').forEach(row => {
          const key = row.dataset.scoreRow!;
          const score = clampScore(scores[key]);
          const color = colorFor(score);
          const valEl = row.querySelector<HTMLElement>('[data-score-value]')!;
          const fillEl = row.querySelector<HTMLElement>('[data-score-fill]')!;
          valEl.textContent = `${score}/100`;
          valEl.style.color = color;
          fillEl.style.width = `${score}%`;
          fillEl.style.background = color;
        });

        const n = clampScore(data.criticalCount);
        footer.textContent = n === 0
          ? 'No critical issues found — but there are still gains available.'
          : `${n} critical issue${n === 1 ? '' : 's'} found.`;

        urlEl.textContent = data.url || url;
        form.style.display = 'none';
        result.hidden = false;
        reportConversion('audit_form');
        setTimeout(() => { upsell.hidden = false; }, 300);
      } catch (err) {
        setRunning(false);
        // Turnstile tokens are single-use — reset so a retry gets a fresh one.
        const turnstile = (window as unknown as { turnstile?: { reset?: () => void } }).turnstile;
        if (turnstile?.reset) { try { turnstile.reset(); } catch { /* noop */ } }
        showError(err instanceof Error ? err.message : 'Network error — please try again.');
      }
    });
  });
</script>

{turnstileSiteKey && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}
