---
// Reusable audit URL form — appears in Section 4 and Section 8 of the homepage.
// Phase 1: shows demo results after a simulated scan.
// Phase 2: will call /.netlify/functions/audit with real PageSpeed + SEO engine.

interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---

<div class={`audit-widget${dark ? ' audit-dark' : ''}`} data-audit-widget>

  <!-- Idle / Running state -->
  <form data-audit-form novalidate>
    <div class="audit-row">
      <label for="audit-url" class="sr-only">Your website URL</label>
      <input
        type="text"
        id="audit-url"
        name="url"
        placeholder="yoursite.com"
        autocomplete="off"
        data-audit-input
        class="audit-input"
      />
      <button type="submit" data-audit-btn class="audit-btn">
        <span data-btn-label>Run Free Audit</span>
        <span data-btn-spinner hidden aria-hidden="true">
          <svg class="spin" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
            <path d="M8 2a6 6 0 0 1 6 6" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Scanning…
        </span>
      </button>
    </div>
    <p class="audit-trust">No email required to see your score. No credit card. No sales call unless you ask.</p>
    <p data-audit-error role="alert" hidden class="audit-error"></p>
  </form>

  <!-- Done state — demo results card (Phase 1) -->
  <div data-audit-result hidden class="audit-result">
    <div class="result-header">
      <span data-result-url class="result-url"></span>
      <span class="result-badge">Report Ready</span>
    </div>
    {[
      ['Performance',           61, '#D97706'],
      ['SEO / Discoverability', 44, '#DC2626'],
      ['AI Readiness',          22, '#DC2626'],
      ['Mobile Experience',     94, '#16A34A'],
      ['Security & Compliance', 55, '#D97706'],
    ].map(([label, score, color]) => (
      <div class="score-row">
        <div class="score-labels">
          <span class="score-label">{label}</span>
          <span class="score-value" style={`color: ${color};`}>{score}/100</span>
        </div>
        <div class="score-track">
          <div class="score-fill" style={`width: ${score}%; background: ${color};`}></div>
        </div>
      </div>
    ))}
    <div class="result-footer">
      3 critical issues found.
    </div>
  </div>

  <!-- Post-audit upsell card -->
  <div data-audit-upsell hidden class="audit-upsell">
    <p class="upsell-eyebrow">YOUR SITE HAS FIXABLE ISSUES</p>
    <p class="upsell-headline">These scores show what's wrong. The Pro Diagnosis + Remedy Package shows you exactly how to fix every issue — with ready-to-paste code.</p>
    <ul class="upsell-list">
      {[
        'Ready-to-paste code fixes for every problem we find',
        '28-point deep scan across all eight layers, explained in plain English',
        'Priority-ranked action list: critical, high-value, and nice-to-have',
        'Delivered within 24 hours',
      ].map(item => (
        <li class="upsell-list-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="upsell-check">
            <circle cx="8" cy="8" r="7" fill="rgba(46,117,182,0.1)" />
            <path d="M5 8l2 2 4-4" stroke="#2E75B6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {item}
        </li>
      ))}
    </ul>
    <a href="/audit#order" class="upsell-btn">Get Your Pro Diagnosis + Remedy Package — $350 →</a>
    <p class="upsell-reassurance">One-time payment · No subscription · Delivered within 24 hours</p>
  </div>
</div>

<style>
  .audit-widget { max-width: 560px; }

  .audit-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .audit-input {
    flex: 1 1 200px;
    padding: 13px 18px;
    border-radius: 10px;
    border: 1.5px solid #d0d9e8;
    background: white;
    color: #0F1F3D;
    font-size: 15px;
    font-family: inherit;
    min-width: 0;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .audit-input::placeholder { color: #8892A0; }
  .audit-input:focus {
    border-color: #2E75B6;
    box-shadow: 0 0 0 3px rgba(46,117,182,0.12);
  }

  .audit-dark .audit-input {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.06);
    color: white;
  }
  .audit-dark .audit-input::placeholder { color: rgba(255,255,255,0.3); }
  .audit-dark .audit-input:focus {
    border-color: rgba(255,255,255,0.35);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.06);
  }

  .audit-btn {
    padding: 13px 24px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    background: linear-gradient(135deg, #2E75B6, #8E44AD);
    color: white;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    box-shadow: 0 6px 20px rgba(46,117,182,0.35);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity 0.2s;
  }
  .audit-btn:disabled { opacity: 0.75; cursor: not-allowed; }

  .audit-trust {
    margin-top: 10px;
    font-size: 12px;
    color: #8892A0;
    line-height: 1.5;
  }
  .audit-dark .audit-trust { color: rgba(255,255,255,0.35); }

  .audit-error {
    margin-top: 8px;
    font-size: 13px;
    color: #DC2626;
    line-height: 1.4;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 0.75s linear infinite; display: block; }

  /* Results card */
  .audit-result {
    background: #F4F6FB;
    border-radius: 14px;
    padding: 24px 28px;
    border: 1px solid #e4eaf5;
  }
  .audit-dark .audit-result {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .result-url {
    font-size: 12px;
    font-family: 'Space Mono', monospace;
    color: #2E75B6;
    word-break: break-all;
  }
  .audit-dark .result-url { color: #4B9FD4; }

  .result-badge {
    font-size: 11px;
    font-weight: 600;
    color: #16A34A;
    background: rgba(22,163,74,0.1);
    padding: 2px 10px;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .score-row { margin-bottom: 10px; }
  .score-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .score-label { font-size: 12px; color: #595959; }
  .audit-dark .score-label { color: rgba(255,255,255,0.65); }
  .score-value { font-size: 12px; font-weight: 700; }

  .score-track {
    height: 5px;
    background: #e4eaf5;
    border-radius: 9999px;
    overflow: hidden;
  }
  .audit-dark .score-track { background: rgba(255,255,255,0.08); }
  .score-fill { height: 5px; border-radius: 9999px; }

  .result-footer {
    margin-top: 14px;
    font-size: 13px;
    color: #8892A0;
  }
  .audit-dark .result-footer { color: rgba(255,255,255,0.5); }
  /* Upsell card */
  .audit-upsell {
    margin-top: 16px;
    background: #fff;
    border: 1px solid #e4eaf5;
    border-top: 3px solid #0F1F3D;
    border-radius: 14px;
    padding: 24px 28px;
  }

  .upsell-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #2E75B6;
    margin: 0 0 10px;
  }

  .upsell-headline {
    font-size: 15px;
    font-weight: 600;
    color: #0F1F3D;
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .upsell-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .upsell-list-item {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 13px;
    color: #595959;
    line-height: 1.45;
  }

  .upsell-check { flex-shrink: 0; margin-top: 1px; }

  .upsell-btn {
    display: block;
    width: 100%;
    padding: 13px 20px;
    border-radius: 10px;
    background: linear-gradient(135deg, #2E75B6, #8E44AD);
    color: white;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    text-align: center;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(46,117,182,0.35);
    transition: opacity 0.2s;
    box-sizing: border-box;
  }
  .upsell-btn:hover { opacity: 0.9; }

  .upsell-reassurance {
    margin: 10px 0 0;
    font-size: 12px;
    color: #8892A0;
    text-align: center;
    line-height: 1.5;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-audit-widget]').forEach(widget => {
    const form    = widget.querySelector<HTMLFormElement>('[data-audit-form]')!;
    const input   = widget.querySelector<HTMLInputElement>('[data-audit-input]')!;
    const btn     = widget.querySelector<HTMLButtonElement>('[data-audit-btn]')!;
    const label   = btn.querySelector<HTMLElement>('[data-btn-label]')!;
    const spinner = btn.querySelector<HTMLElement>('[data-btn-spinner]')!;
    const errEl   = widget.querySelector<HTMLElement>('[data-audit-error]')!;
    const result  = widget.querySelector<HTMLElement>('[data-audit-result]')!;
    const upsell  = widget.querySelector<HTMLElement>('[data-audit-upsell]')!;
    const urlEl   = result.querySelector<HTMLElement>('[data-result-url]')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errEl.hidden = true;
      errEl.textContent = '';

      let url = input.value.trim();
      if (!url) {
        errEl.textContent = 'Please enter your website URL.';
        errEl.hidden = false;
        input.focus();
        return;
      }
      if (!/^https?:\/\//i.test(url)) url = 'https://' + url;
      try { new URL(url); } catch {
        errEl.textContent = "That doesn't look like a valid URL — try something like yoursite.com";
        errEl.hidden = false;
        input.focus();
        return;
      }

      // Running state
      btn.disabled = true;
      label.hidden = true;
      spinner.hidden = false;

      // Phase 1: demo results after simulated scan delay
      setTimeout(() => {
        form.style.display = 'none';
        urlEl.textContent = url;
        result.hidden = false;
        setTimeout(() => { upsell.hidden = false; }, 300);
      }, 2200);
    });
  });
</script>
