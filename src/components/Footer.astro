---
import { SITE_NAME, NAV_LINKS, SOCIAL_LINKS } from '../config/site';
---

<footer style="background: #0F1F3D; padding-top: 56px;">
  <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px 48px; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 32px;">

    <!-- Brand -->
    <div>
      <div style="margin-bottom: 12px;">
        <svg viewBox="0 0 260 56" fill="none" xmlns="http://www.w3.org/2000/svg" style="height: 40px; width: auto; flex-shrink: 0;" aria-hidden="true">
          <defs>
            <linearGradient id="gmark-foot" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#1F3864" />
              <stop offset="100%" stop-color="#2E75B6" />
            </linearGradient>
          </defs>
          <polygon points="4,6 44,28 4,50" fill="url(#gmark-foot)" />
          <text x="9" y="35" font-family="Georgia, serif" font-size="22" font-weight="700" fill="white">S</text>
          <text x="50" y="33" font-family="'Space Grotesk', sans-serif" font-size="19" font-weight="700" fill="white" letter-spacing="-0.3">{SITE_NAME}</text>
        </svg>
      </div>
      <div style="font-size: 12px; color: rgba(255,255,255,0.3); letter-spacing: 0.5px;">Serving small businesses nationwide</div>
    </div>

    <!-- Navigation -->
    <div style="display: flex; flex-direction: column; gap: 10px;">
      {NAV_LINKS.map(({ label, href }) => (
        <a href={href} style="color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none; transition: color 0.2s;" class="footer-link">
          {label}
        </a>
      ))}
      <a href="/privacy" style="color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none; transition: color 0.2s;" class="footer-link">
        Privacy Policy
      </a>
    </div>

    <!-- Contact & Social -->
    <div>
      <div style="margin-bottom: 10px;">
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Sequel Web Studio on LinkedIn"
          class="social-link"
          style="display: inline-flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); text-decoration: none; font-size: 13px; transition: color 0.2s;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 18px; height: 18px; flex-shrink: 0;" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
      <div style="margin-bottom: 16px;">
        <a
          href={SOCIAL_LINKS.clutch}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Sequel Web Studio on Clutch"
          class="social-link"
          style="display: inline-flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.4); text-decoration: none; font-size: 13px; transition: color 0.2s;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 18px; height: 18px; flex-shrink: 0;" aria-hidden="true">
            <path d="M19.07 4.93A10 10 0 1 0 19.07 19.07L16.6 16.6A6.5 6.5 0 1 1 16.6 7.4Z"/>
          </svg>
          Clutch
        </a>
      </div>
      <div style="font-size: 11px; color: rgba(255,255,255,0.25);">
        &copy; {new Date().getFullYear()} {SITE_NAME}. Built by hand.
      </div>
    </div>
  </div>

  <!-- Gradient accent bar -->
  <div style="height: 4px; background: linear-gradient(to right, #2E75B6, #8E44AD);"></div>
</footer>

<style>
  .footer-link:hover {
    color: rgba(255,255,255,0.85) !important;
  }
  .social-link:hover {
    color: rgba(255,255,255,0.85) !important;
  }
</style>
