---
import { SITE_NAME, NAV_LINKS, CONTACT_EMAIL } from '../config/site';
---

<footer style="background: #0F1F3D; padding-top: 56px;">
  <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px 48px; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 32px;">

    <!-- Brand -->
    <div>
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
        <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #1F3864, #2E75B6); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 17px; font-family: Georgia, serif; flex-shrink: 0;">S</div>
        <span style="font-size: 15px; font-weight: 700; color: white;">{SITE_NAME}</span>
      </div>
      <div style="font-size: 12px; color: rgba(255,255,255,0.3); letter-spacing: 0.5px;">Northern Tarrant County, TX</div>
    </div>

    <!-- Navigation -->
    <div style="display: flex; flex-direction: column; gap: 10px;">
      {NAV_LINKS.map(({ label, href }) => (
        <a href={href} style="color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none; transition: color 0.2s;" class="footer-link">
          {label}
        </a>
      ))}
      <a href="/privacy" style="color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none; transition: color 0.2s;" class="footer-link">
        Privacy Policy
      </a>
    </div>

    <!-- Contact -->
    <div>
      <a href={`mailto:${CONTACT_EMAIL}`} style="color: #2E75B6; font-weight: 600; font-size: 14px; display: block; margin-bottom: 8px; text-decoration: none;">
        {CONTACT_EMAIL}
      </a>
      <div style="font-size: 11px; color: rgba(255,255,255,0.25);">
        &copy; {new Date().getFullYear()} {SITE_NAME}. Built by hand.
      </div>
    </div>
  </div>

  <!-- Gradient accent bar -->
  <div style="height: 4px; background: linear-gradient(to right, #2E75B6, #8E44AD);"></div>
</footer>

<style>
  .footer-link:hover {
    color: rgba(255,255,255,0.85) !important;
  }
</style>
