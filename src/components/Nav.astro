---
import { SITE_NAME, NAV_LINKS } from '../config/site';
const { pathname } = Astro.url;
---

<a href="#main-content" class="skip-nav">Skip to main content</a>

<header
  id="main-nav"
  style="position: fixed; top: 0; left: 0; right: 0; z-index: 200; height: 68px; transition: background 0.3s, box-shadow 0.3s, backdrop-filter 0.3s;"
>
  <div style="max-width: 1160px; margin: 0 auto; padding: 0 32px; height: 100%; display: flex; align-items: center; justify-content: space-between;">

    <!-- Logo — unified SVG lockup matching approved Logo 2 design -->
    <a href="/" style="display: flex; align-items: center; text-decoration: none;" aria-label="Sequel Web Studio — home">
      <svg viewBox="0 0 260 56" fill="none" xmlns="http://www.w3.org/2000/svg" style="height: 40px; width: auto; flex-shrink: 0;" aria-hidden="true">
        <defs>
          <linearGradient id="gmark-nav" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#1F3864" />
            <stop offset="100%" stop-color="#2E75B6" />
          </linearGradient>
        </defs>
        <polygon points="4,6 44,28 4,50" fill="url(#gmark-nav)" />
        <text x="9" y="35" font-family="Georgia, serif" font-size="22" font-weight="700" fill="white">S</text>
        <text id="nav-wordmark" x="50" y="33" font-family="'Space Grotesk', sans-serif" font-size="19" font-weight="700" fill="white" letter-spacing="-0.3" style="transition: fill 0.3s;">{SITE_NAME}</text>
      </svg>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main navigation" class="hidden md:flex" style="align-items: center; gap: 2px;">
      {NAV_LINKS.filter(l => l.href !== '/').map(({ label, href }) => {
        const isActive = pathname === href || (href !== '/' && pathname.startsWith(href + '/'));
        return (
          <a
            href={href}
            class={`nav-link${isActive ? ' nav-link-active' : ''}`}
            style="padding: 6px 13px; border-radius: 6px; font-size: 13px; font-weight: 500; text-decoration: none; transition: color 0.3s, background 0.3s; color: rgba(255,255,255,0.8);"
          >
            {label}
          </a>
        );
      })}
      <a
        href="/audit#order"
        style="margin-left: 10px; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; padding: 9px 18px; border-radius: 8px; font-size: 13px; font-weight: 700; text-decoration: none; box-shadow: 0 4px 14px rgba(46,117,182,0.3); transition: opacity 0.2s; white-space: nowrap;"
      >
        Get Your Diagnosis — $350
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden"
      style="background: none; border: none; cursor: pointer; color: white; padding: 8px;"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    aria-label="Mobile navigation"
    class="hidden md:hidden"
    style="background: rgba(255,255,255,0.97); backdrop-filter: blur(16px); border-top: 1px solid #e4eaf5;"
  >
    <div style="max-width: 1160px; margin: 0 auto; padding: 16px 32px; display: flex; flex-direction: column; gap: 4px;">
      {NAV_LINKS.map(({ label, href }) => (
        <a
          href={href}
          style="color: #595959; padding: 10px 4px; font-size: 15px; font-weight: 500; text-decoration: none; border-bottom: 1px solid #f0f3f9;"
        >
          {label}
        </a>
      ))}
      <a
        href="/audit#order"
        style="margin-top: 12px; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; text-align: center; padding: 12px; border-radius: 8px; font-size: 14px; font-weight: 700; text-decoration: none;"
      >
        Get Your Diagnosis — $350
      </a>
    </div>
  </nav>
</header>

<script>
  (() => {
    const nav      = document.getElementById('main-nav');
    const wordmark = document.getElementById('nav-wordmark');
    const navLinks = document.querySelectorAll<HTMLElement>('.nav-link');
    const toggle    = document.getElementById('menu-toggle');
    const menu      = document.getElementById('mobile-menu');
    const iconOpen  = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    if (!nav || !wordmark || !toggle || !menu || !iconOpen || !iconClose) return;

    function updateNav() {
      const scrolled = window.scrollY > 40;
      nav!.style.background       = scrolled ? 'rgba(255,255,255,0.95)' : 'transparent';
      nav!.style.backdropFilter   = scrolled ? 'blur(16px)' : 'none';
      nav!.style.boxShadow        = scrolled ? '0 2px 20px rgba(15,31,61,0.08)' : 'none';
      wordmark!.style.setProperty('fill', scrolled ? '#0F1F3D' : 'white');
      navLinks.forEach(l => {
        if (l.classList.contains('nav-link-active')) {
          l.style.color      = scrolled ? '#2E75B6' : 'white';
          l.style.background = scrolled ? 'rgba(46,117,182,0.1)' : 'rgba(255,255,255,0.15)';
          l.style.fontWeight = '700';
        } else {
          l.style.color      = scrolled ? '#595959' : 'rgba(255,255,255,0.8)';
          l.style.background = '';
          l.style.fontWeight = '';
        }
      });
      (toggle as HTMLButtonElement).style.color = scrolled ? '#0F1F3D' : 'white';
    }

    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    toggle.addEventListener('click', () => {
      const isOpen = !menu!.classList.contains('hidden');
      menu!.classList.toggle('hidden');
      iconOpen!.classList.toggle('hidden');
      iconClose!.classList.toggle('hidden');
      toggle!.setAttribute('aria-expanded', String(!isOpen));
      toggle!.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
    });

  })();
</script>
