---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { SITE_NAME, SITE_URL, LOCAL_BUSINESS_SCHEMA, WEBSITE_SCHEMA } from '../config/site';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  /**
   * minimal: hides the full site Nav and Footer — used by dedicated ad landing
   * pages so paid visitors have one job (convert) instead of a menu of exits.
   */
  minimal?: boolean;
  /**
   * noindex: tells search engines not to list this page in organic results.
   * Used by ad landing pages so they never compete with the main site pages.
   */
  noindex?: boolean;
}

const {
  title,
  description = 'Sequel Web Studio builds custom-coded websites for small businesses across the US — starting at $1,000.',
  // Default so every page (incl. /privacy and /404) always ships a share image
  // and a large social card instead of falling back to a blank summary.
  ogImage = `${SITE_URL}/images/og-home.png`,
  ogType = 'website',
  minimal = false,
  noindex = false,
} = Astro.props;

const pageTitle    = title.includes(SITE_NAME) ? title : `${title} | ${SITE_NAME}`;
const canonicalUrl = `${SITE_URL}${Astro.url.pathname}`;
const schema        = JSON.stringify(LOCAL_BUSINESS_SCHEMA);
const websiteSchema = JSON.stringify(WEBSITE_SCHEMA);

const ga4Id       = import.meta.env.PUBLIC_GA4_ID;
const adsId       = import.meta.env.PUBLIC_GOOGLE_ADS_ID;
const cookieYesId = import.meta.env.PUBLIC_COOKIEYES_ID;
const loaderId    = ga4Id || adsId;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type"         content={ogType} />
    <meta property="og:site_name"    content={SITE_NAME} />
    <meta property="og:locale"       content="en_US" />
    <meta property="og:title"        content={pageTitle} />
    <meta property="og:description"  content={description} />
    <meta property="og:url"          content={canonicalUrl} />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content={`${SITE_NAME}: AI search visibility for small businesses`} />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <meta name="twitter:image:alt"   content={`${SITE_NAME}: AI search visibility for small businesses`} />

    <!-- Google Fonts: Space Grotesk + Space Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" /></noscript>

    <!-- Favicon: SVG (modern browsers) + PNG fallbacks -->
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%231F3864'/%3E%3Ctext x='50%25' y='58%25' text-anchor='middle' font-family='Georgia,serif' font-size='38' font-weight='700' fill='white'%3ES%3C/text%3E%3C/svg%3E"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Schema.org JSON-LD (D8) -->
    <script type="application/ld+json" set:html={schema} />
    <script type="application/ld+json" set:html={websiteSchema} />

    <!-- Per-page head additions (e.g. FAQPage schema) -->
    <slot name="head" />

    {cookieYesId && (
      <script
        is:inline
        defer
        id="cookieyes"
        type="text/javascript"
        src={`https://cdn-cookieyes.com/client_data/${cookieYesId}/script.js`}
      />
    )}

    {loaderId && (
      <>
        <script define:vars={{ ga4Id, adsId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function(){ window.dataLayer.push(arguments); };
          gtag('consent', 'default', {
            analytics_storage: 'denied',
            ad_storage: 'denied',
          });
          gtag('js', new Date());
          if (ga4Id) gtag('config', ga4Id);
          if (adsId) gtag('config', adsId);
        </script>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${loaderId}`} />
      </>
    )}
  </head>
  <body>
    {minimal ? (
      <header style="position: absolute; top: 0; left: 0; right: 0; z-index: 10; padding: 22px 32px;">
        <a href="/" style="display: inline-flex; align-items: center; gap: 10px; text-decoration: none;">
          <span style="display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 8px; background: linear-gradient(135deg, #2E75B6, #8E44AD); color: white; font-weight: 700; font-size: 18px; font-family: Georgia, serif;">S</span>
          <span style="font-weight: 700; font-size: 17px; color: white; letter-spacing: -0.3px;">Sequel Web Studio</span>
        </a>
      </header>
    ) : (
      <Nav />
    )}
    <main id="main-content">
      <slot />
    </main>
    {minimal ? (
      <footer style="background: #0F1F3D; padding: 28px 32px; text-align: center;">
        <p style="font-size: 12px; color: rgba(255,255,255,0.5); margin: 0;">
          © {new Date().getFullYear()} Sequel Web Studio · Serving small businesses nationwide ·
          <a href="/privacy" style="color: rgba(255,255,255,0.65);">Privacy Policy</a>
        </p>
      </footer>
    ) : (
      <Footer />
    )}

    <!-- Scroll reveal observer — wires up all .reveal elements -->
    <script>
      const io = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
        { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    </script>
  </body>
</html>
