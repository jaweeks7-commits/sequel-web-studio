# ── Active (in use) ───────────────────────────────────────────────────────────
# Site + contact
PUBLIC_SITE_URL=https://sequelwebstudio.com
PUBLIC_CONTACT_EMAIL=joe@sequelwebstudio.com

# Audit build/delivery pipeline (scripts/)
AUDIT_OUTPUT_DIR=C:\Sequel Audit Deliverables

# Analytics & consent (loaders no-op when the ID is empty)
PUBLIC_GA4_ID=
PUBLIC_GOOGLE_ADS_ID=
PUBLIC_ADS_LABEL_PURCHASE=
PUBLIC_ADS_LABEL_CONTACT=
PUBLIC_ADS_LABEL_AUDIT_FORM=
PUBLIC_COOKIEYES_ID=

# Bot protection (Cloudflare Turnstile; server verify no-ops until the secret is set)
# Also gates the Free Lite Audit widget's Turnstile challenge on the homepage.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Free Lite Audit — Google PageSpeed Insights key for the live homepage scan.
# Optional: when empty, the scan falls back to a TTFB-based performance estimate.
PAGESPEED_API_KEY=

# Email — audit receipts/briefings/delivery
RESEND_API_KEY=re_...
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Payments — Pro Diagnosis checkout
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Free-audit log (Google Sheet) — the daily digest appends each day's requests
# here as a permanent archive. All three required; when any is empty the append
# no-ops and the digest behaves as before. GOOGLE_SERVICE_ACCOUNT_KEY is the
# service account's private_key (keep the literal \n sequences).
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
